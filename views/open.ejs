        function genRandName(sed, culture) {
            let seed = sed + culture;
            //const onsets = ['b','sb','c','ch','sk','sc','d','f','g','j','k','l','m','n','','p','r','chr','cr','shr','s','sh','th','tsh','v','w','tw','x','y','z','kr','qu','wh'];
            //const nuclei = ['a','e','i','o','u','ae','ai','au','ea','ei','eo','ia','ie','io','oa','oe','oi','ou','ua','ue',];
            //const codas = ['b','bs','','ch','ck','cks','d','ds','f','g','k','l','lch','lst','m','n','ng','','p','r','rch','rck','rsh','rth','s','sh','th','v','w','x','y','z','','','','',"","","","","","","","","","","","","","",'','','',"","","","","","","","","","","","","","",'','','',"","","","","","","","","","","","","",""];
            const nuclei = ["a","e","i","o","u","y","à","è","ì","ò","ù","â","ê","ï","õ","ä","ö","ü","å","ā","ē","ī","ū","ō","â","ê","î","ô","û","á","é","í","ó","ú","ø"];
            const obstruents = ["b","c","d","f","g","h","k","p","q","s","t","v","x","ck","ch","sh","th","ç","š","ž"];
            const sonorants = ["m","n","l","j","r","w","dg","ng","č","ñ"];
            let allowsNullOnsets = Math.floor(2 * twodorandom(seed, 0.2));
            let syllableStructure = Math.floor(4 * twodorandom(seed, 0.5));
            let allowDipthongs = Math.floor(2 * twodorandom(seed, 0.6));
            let numNuclei = Math.max(1,Math.floor(nuclei.length * twodorandom(seed, 0.6)));
            let numSonorants = Math.max(1, Math.floor(sonorants.length * twodorandom(seed, 0.6)));
            let numObstruents = Math.max(3,Math.floor(obstruents.length * twodorandom(seed, 0.6)));
            
            let returnist = [];
            const nCount = 2 + Math.floor(4 *twodorandom(culture,0.977743));
            for(let i = 0; i < nCount; i++) {

                let on = "";
                let sCount = 1+Math.floor(3*twodorandom(seed,twodorandom(i, 0.85345)));
                for(let j =0; j < sCount; j++) {
                    let chanceToOnset = 1;
                    if (allowsNullOnsets) {
                        chanceToOnset = 0.8;
                    }
                    if (chanceToOnset > (twodorandom(i + seed,j+0.2))) {
                        let doing = Math.floor(2 * twodorandom(i + seed, j+ 0.3));
                        if (syllableStructure >= 2 && 0.36 < twodorandom(i+ seed, j +0.35)) {
                            doing = 2;
                        }
                        if (doing == 0 || doing ==2) {
                            on = on.concat(obstruents[Math.floor(numObstruents * twodorandom(i + 0.6325, twodorandom(seed, j)))]);
                        }
                        if (doing > 0) {
                            on = on.concat(sonorants[Math.floor(numSonorants * twodorandom(i + 0.325, twodorandom(seed, j)))]);
                        }
                    }
                    //on = on.concat(onsets[Math.floor(onsets.length * twodorandom(i + 0.325, twodorandom(seed, j)))]);
                    on = on.concat(nuclei[Math.floor(numNuclei * twodorandom(i + 0.944, twodorandom(seed, j)))]);
                    if (allowDipthongs && twodorandom(i+seed, j +0.41)>0.71) {
                        on = on.concat(nuclei[Math.floor(numNuclei * twodorandom(i + 0.254, twodorandom(seed, j)))]);
                    }
                    if (syllableStructure != 0 && 0.5 > (twodorandom(i + seed,j+0.2))) {
                        let doing = Math.floor(2 * twodorandom(i + seed, j+ 0.3));
                        if (syllableStructure == 3 && 0.11 < twodorandom(i+ seed, j +0.235)) {
                            doing = 2;
                        }
                        if (doing == 0 || doing ==2) {
                            on = on.concat(sonorants[Math.floor(numSonorants * twodorandom(i + 0.6325, twodorandom(seed, j)))]);
                        }
                        if (doing > 0) {
                            on = on.concat(obstruents[Math.floor(numObstruents * twodorandom(i + 0.83265, twodorandom(seed, j)))]);
                        }
                    }
                }
                on = on.charAt(0).toUpperCase() + on.slice(1);
                returnist.push(on);
            }
            return returnist;
        }

        function randomItem(seed) {
            let ret = new thing();
            ret.capacity = (Math.floor((1/twodorandom(seed,9.35))-1))/1000;
            if (twodorandom(seed,0.256) > 0.5) {
                ret.hasHandle = true;
                ret.handleLength = ((1/twodorandom(seed,0.7453))-1)/10;
                ret.handleRadius = ((1/twodorandom(seed,0.533))-1)/100;
                ret.handleMaterial=randPracticalMaterial(playerx,playery,twodorandom(seed,0.98557));

                //
            }
            if (twodorandom(seed,0.22456) > 0.5) {
                ret.slashes = true;
            }
            if (twodorandom(seed,0.2231) > 0.5) {
                ret.pierces = true;
            }
            ret.bladeLength = ((1/twodorandom(seed,0.72453))-1)/10;
            ret.bladeThickness = ((1/twodorandom(seed,0.5333))-1)/200;
            ret.bladeDepth = ((1/twodorandom(seed,0.5733))-1)/50;
            ret.addlVolume = (Math.floor((1/twodorandom(seed,9.1325))-1))/1000;
            ret.costMultiplier = ((1/twodorandom(seed,0.824))-1);

            ret.material=randPracticalMaterial(playerx,playery,twodorandom(seed,0.457));

            if (twodorandom(seed,0.256) > 0.5) {
                ret.wearable = true;
                for (let i = 0; i < 21; i++) {
                    if(twodorandom(seed,twodorandom(i,0.352))<0.05) {
                        ret.whereArmors.push(i);
                    }
                }
                ret.armorialThickness = ((1/twodorandom(seed,0.794763))-1)/500;
                ret.armorialSize = 26 * twodorandom(seed, 0.53789);
            }
            ret.calculateSecondaryAttributes();
            return ret;
        }

