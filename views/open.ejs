        function genProfession(person,cropVec,landUseVec,regopop) {
            let chanceOfOrch = (((32**2)*(landUseVec[3]-landUseVec[2]))/regopop);
            let chanceOfFarm = (((32 ** 2) * (landUseVec[2] - landUseVec[1])) / regopop);
            //the following code handles if there arent any possible crops.
            let farmPossible = false;
            let hortPossible = false;
            cropVec.forEach((e)=>{
                if (e.isTree) {
                    hortPossible = true;
                } else {
                    farmPossible = true;
                }
            });
            if (!hortPossible) {
                chanceOfOrch = 0;
            }
            if (!farmPossible) {
                chanceOfFarm = 0;
            }
            let sume = chanceOfOrch + chanceOfFarm;
            //console.log(cropVec);
            if (sume > 0.99) {
                chanceOfOrch *= (0.99/sume);
                chanceOfFarm *= (0.99/sume);
            }
            let pssd = person.CID.ident;
            let mark = twodorandom(pssd,0.2634);
            if (mark < chanceOfOrch) {
                //culture horter
                let emp = [];
                let soom = 0;
                cropVec.forEach((u)=>{
                    if (u.isTree) {
                        emp.push(u);
                        soom += u.thingy.rareness;
                    }
                });
                let rondto = soom * twodorandom(pssd,0.26723);
                let i = 0;
                while (rondto > emp[i].thingy.rareness) {
                    rondto -= emp[i].thingy.rareness;
                    i++;
                }
                return new profession ("farmer", emp[i]);
            } else if (mark < chanceOfOrch + chanceOfFarm) {
                //farmer
                let emp = [];
                let soom = 0;
                //console.log(cropVec);
                cropVec.forEach((u) => {
                    if (!u.isTree) {
                        emp.push(u);
                        soom += u.thingy.rareness;
                    }
                });
                let rondto = soom * twodorandom(pssd, 0.26623);

                let i = 0;
                while (rondto > emp[i].thingy.rareness) {
                    rondto -= emp[i].thingy.rareness;
                    i++;
                }
                return new profession("farmer", emp[i]);
            } else {
                return new profession("vagrant");
            }
        }

        function giveCoinsTo(dollarAmount, high, med, low, inventory) {
            let hpv = Object.assign(new thing(), high);
            let mpv = Object.assign(new thing(), med);
            let lpv = Object.assign(new thing(), low);
            hpv.stackSize = 0;
            mpv.stackSize = 0;
            lpv.stackSize = 0;
            let rem = dollarAmount;
            while (rem > 2 * high.totalValue) {
                rem -= high.totalValue;
                hpv.stackSize ++;
            }
            while (rem > 2 * med.totalValue) {
                rem -= med.totalValue;
                mpv.stackSize ++;
            }
            while (rem >= low.totalValue) {
                rem -= low.totalValue;
                lpv.stackSize ++;
            }
            if (hpv.stackSize > 0) {
                hpv.calculateSecondaryAttributes();
                inventory.push(hpv);
            }
            if (mpv.stackSize > 0) {
                mpv.calculateSecondaryAttributes();
                inventory.push(mpv);
            }
            if (lpv.stackSize > 0) {
                lpv.calculateSecondaryAttributes();
                inventory.push(lpv);
            }
        }

