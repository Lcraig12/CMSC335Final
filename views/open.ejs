                if (!queryItemCurrent || queryItemCurrent == player) {
                    if (this == player) {
                        gamelog("No valid conversation target selected.");
                    }
                } else {
                    this.conversationPartner = queryItemCurrent;
                    this.giveGreeting(this.conversationPartner);
                    this.conversationPartner.giveGreeting(this);
                    talkDisplay(["Buy","Sell","Quit","Inquire about profession"]);
                }
