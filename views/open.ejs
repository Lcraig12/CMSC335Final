        class toothpick {
            constructor(x, y, parent, parentx, parenty, parentseed, culture) {
                this.x = x;
                this.y = y;

                if(parent != undefined) {
                    this.parent = parent;
                }
                
                this.parentx = parentx;
                this.parenty = parenty;
                this.culture = culture;
                this.parentseed = parentseed;
                //let hwc = twodorandom(63,61);
                //console.log(paret.x);
                //console.log(originalSeed);
                this.z = allGensPerlin(x + REGIONSIZE*parentx, y + REGIONSIZE*parenty,twodorandom(Number(originalSeed), 1.613));
                //this.z = (MAXELEV * rawPerlin(x + REGIONSIZE*paret.x, y + REGIONSIZE*paret.y, 8,twodorandom(Number(originalSeed), 1.613)));
                //console.log(this.z);
                this.tile = "|"
                this.biome="";
                this.bkgc = "#fc03df";//error color magenta
                this.moisture = 1;//tbd
                this.detmoist();
                this.temp = -1;
                this.dettemp();
                this.thingsHere = [];
                this.detbiome();
                this.notable = false;
                this.builtTile="";
                this.builtColor="";
                this.isSolid = false;
                
                this.fogc = "#000000";
                this.finalTile = "";
                this.rockType = undefined;
                if (this.parent) {
                    this.rockType = this.parent.rockType;
                } else {
                    this.rockType = detRockType(parentx,parenty);
                }
                
                this.bkgc = this.detbackolor();
                this.enforceHomeostasis();
            }
                
            detbackolor() { //also determines tile and tilecolor
                let c = "";
                if (globalMode === 0) {

                    let hs = 256*this.z/MAXELEV;
                    //let is = hs*256;
                    //is = is % 256;
                    c = crergba(hs,hs,hs);
                    if (this.z <= SEALEVEL) {
                        c = crergba(100,149,237);
                        this.tile = randomWater();
                        
                    }
                    //console.log(c);
                    this.bkgc= c;
                } else if (globalMode === 1) {
                    c = this.makeBackGeneral(minTemp,maxTemp,2.0,this.temp);
                }else if (globalMode === 3){
                    //console.log(this.temp);
                    let a = this.makeBackGeneral(minTemp,maxTemp,2.0,this.temp);
                    let b = this.makeBackGeneral(maxDesert,minDesert,2.0,this.moisture);
                    let d = this.makeBackGeneral(maxDesert,minDesert,256/MAXELEV,this.z);
                    c = comborgbs(d, comborgbs(a,b));
                    this.bkgc = c;
                } else if (globalMode === 4) {    
                    let w1 = this.makeBackGeneral([255,0,0],[0,255,255],256,this.culture);
                    let w2 = this.makeBackGeneral([255,0,0],[0,0,0],256,twodorandom(this.culture, 0.2363));
                    let w3 = this.makeBackGeneral([0,255,0],[0,0,0],256,twodorandom(this.culture, 0.13353));
                    let w4 = this.makeBackGeneral([0,0,255],[0,0,0],256,twodorandom(this.culture, 0.7363));
                    
                    
                    c = comborgbs(comborgbs(w1,w2),comborgbs(w3,w4));
                    
                } else if (globalMode === 5) {    
                    //console.log(findnumber(this.biome,biomes));
                    c = this.makeBackGeneral([0,255,255],[255,0,0],23.2,findnumber(this.biome,biomes));//23.2 less than is 256/num biomes
                } else if (globalMode === 6) {
                    c = this.rockType.color;
                } else {
                    c = this.makeBackGeneral(maxDesert,minDesert,2.0,this.moisture);
                }
                //console.log(c);
                
                
                if (this.builtColor != "") {
                    c = this.builtColor;
                }
                this.bkgc = c;
                this.detTile();
                return c;
            }

            detTile() {
                if(this.thingsHere.length != 0) {
                    this.finalTile = this.thingsHere[0].tile;
                    //console.log(this.thingsHere);
                    this.fogc = this.thingsHere[0].material.color;
                } else {
                    this.finalTile = this.tile;
                    this.fogc = "#000000";
                    if (this.builtColor != "") {
                        this.finalTile = this.builtTile;
                    }
                }
                
            }

            makeBackGeneral(minarrm, maxarrm, toscale, arg) {
                //console.log("new");
                //console.log(toscale);
                //console.log(arg);
                let hs = (toscale*arg);
                //let hs = (toscale*arg*256)%256; //this is debug mode
                let a = (hs*maxarrm[0] + (256.0-hs)*minarrm[0])/256.0;
                let b = (hs*maxarrm[1] + (256.0-hs)*minarrm[1])/256.0;
                let d = (hs*maxarrm[2] + (256.0-hs)*minarrm[2])/256.0;
                
                //console.log(hs);
                //console.log(a);
                //console.log(b);
                //console.log(d);
                let c = crergba(a,b,d);
                //console.log(c);
                if (this.z <= SEALEVEL) {
                    c = crergba(100,149,237);
                }
                //console.log(c);
                this.bkgc= c;
                return c;
            }

            dettemp() {//temp is on a scale of 0 to 128
                let hw = Math.abs((REGIONSIZE*this.parentx) + this.x);
                let latfact = 64/((hw*0.0000005)+1); // that 0.0005 number = the smaller it is, the longer it takes for the temp to change
                let elevmult = 64-((64.0/MAXELEV) * this.z);
                this.temp = (latfact + ((Math.sqrt(latfact))*(Math.sqrt(elevmult))));//yes, numbers are correct
            }      

            detbiome() { 
                //console.log(this.temp);
                let ctemp = 2*this.temp;
                let cmoist = 2*this.moisture;
                let biome =" ";
                if (ctemp < 32 ) {
                    biome = "X"
                } else if (ctemp < 64) {
                    biome = "_"
                } else if (ctemp < 96) {
                    if (cmoist < 32 ) {
                        biome = "🏜️";
                    } else if (cmoist < 64) {
                        biome = "S";
                    } else if (cmoist < 128) {
                        biome = "🌲"
                    } else {
                        biome ="🍀"
                    }
                } else if (ctemp < 160) {
                    if (cmoist < 64 ) {
                        biome = "🏜️";
                    } else if (cmoist < 96) {
                        biome = "S";
                    } else if (cmoist < 160) {
                        biome = "🌳"
                    } else {
                        biome ="🍀"
                    }
                } else {
                    if (cmoist < 64 ) {
                        biome = "🌵";
                    } else if (cmoist < 128) {
                        biome = "🐘";
                    } else if (cmoist < 192) {
                        biome = "🌳"
                    } else {
                        biome ="🌴"
                    }
                }
                


                if(this.z>SEALEVEL){
                    
                    this.biome = biome;
                    let rand=twodorandom(Number(this.parentseed),twodorandom(this.x,this.y));
                    //console.log(this.paret.localseed);
                    if (this.parent == undefined) {//so it still shows foliage when zoomed out.
                        let k = this.tile=placeFloraFauna(rand,twodorandom(rand,twodorandom(this.moisture,this.y)),biome,(REGIONSIZE*this.parentx) + this.x,(REGIONSIZE*this.parenty)+this.y);
                        if (k) {
                            this.tile = k.tile;
                        } else {
                            this.tile = "|";
                        }
                    } else {
                        if (((this.parentx * REGIONSIZE) + this.x == 9564) && (1818118181 == (this.parenty * REGIONSIZE) + this.y)) {
