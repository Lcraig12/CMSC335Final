            dooo(actionn) {
                if (this.isLiving) {
                    if (actionn.type == 0) {//attack
                        this.attack(actionn.target,1);
                    } else if (actionn.type == 1) {//move
                        //console.log("DoingWalk");
                        if (actionn.direction == 0)  {
                            this.moveTo(this.x + 1, this.y);
                        } else if (actionn.direction == 1)  {
                            this.moveTo(this.x - 1, this.y);
                        } else if (actionn.direction == 2)  {
                            this.moveTo(this.x, this.y +1);
                        } else {
                            this.moveTo(this.x, this.y -1);
                        }
                    }
                }
                this.taskCount--;
                if (this.taskCount <= 0) {
                    this.think();
                }
            }

