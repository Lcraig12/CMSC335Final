    <div class="outergrid" id="og" hidden="false">
        <div class = "player">
            <h1><a class="fancy">POWX</a> 0.9.3</h1>
            <hr>
            <p>
                <a id = "tilearea"></a>
                <br>
                <a id = "namearea"></a>
                <br>
                <a id = "genericnamearea"></a>
                <br>
                <a>Height: </a><a id = "heightarea"></a>
                <br>
                <a>Mass: </a><a id = "weightarea"></a>
                <br>
                <a>Stamina: </a><a id = "staminaarea"></a>
                <br>
                <a>Melee Skill: </a><a id = "meleeskillarea"></a>
                <br>
                <a>Right Hand: </a><a id = "righthandarea"></a>
                <br>
                <a>Left Hand: </a><a id = "lefthandarea"></a>
                <br>
                
            </p>
            <textarea id = "playerinfo" disabled></textarea>
            <hr>
            <fieldset class = "slightlysmaller">
                <legend>Game Log</legend>
                <p id = "gl0"></p>
                <p id = "gl1"></p>
                <p id = "gl2"></p>
                <p id = "gl3"></p>
                <p id = "gl4"></p>
                <p id = "gl5" style ="background-color: beige;"></p>
            </fieldset>
            <hr>
            <!-- KEEP THE DATA THE SAME -->
            <% 
                // This line MUST exist before you try to use the variable below
                const initialData = JSON.parse(world); 
            %>
            <form method="post" action = "/home">
                <button type ="button" onclick="exportWorld()">Save World</button>
                <!--<button id = "iwb" type ="button" onclick="importWorld()">Import World</button>>-->
                <br>
                <div hidden>
                <textarea id="jason" name = "world" ><%- world %></textarea>
                <!-- TODO:  updated along with the above -->
                <textarea id = "thomas" name="worldname" ><%= initialData.name %></textarea>
                <textarea id = "thomastwo" name="username"><%= initialData.username %></textarea>
                </div>
                <br>
                <button type = "submit">Exit Game</button>
                <br>
            </form>
			
        </div>
        <div class ="maingrid" id="meangrid" >
        </div>
        <div class ="controls" >
            <h id="status"></h>
            <button id = "gwb" type="button" onclick="first()">Generate World</button>
            Seed: <input type="number" id="seedling" value="0.41137358">
            <br>
            <a>X Position: </a><a id="xdata"></a><a> Y Position: </a><a id="ydata"></a><a> Altitude: </a><a id="altdata"></a>
            <br>
            <a> Climate: </a><a id="tempdata"></a><a> Precipitation: </a><a id="moistdata"></a><a> Biome: </a><a id="biomedata"></a>
            <br>
            <a>Culture: </a><a id="culturedata"></a><a id = "cityname"></a>
            <br>
            <a>Time: </a><a id="timedataa"></a><a> | </a><a id="timedata"></a></a>
            <br><a> Rock: </a><a id="rockdata"></a><br>
            <a>Temperature: </a><a id="newtempdata"></a><a> K</a>
            <br>
            <fieldset>
                <legend>Overlays</legend>
            <button type ="button" onclick="displayTemp()">Temperature</button>
            <button type ="button" onclick="displayMoist()">Precipitation</button>
            <button type ="button" onclick="displayElev()">Elevation</button>
            <button type ="button" onclick="displayCulture()">Culture</button>
            <button type ="button" onclick="displayBiome()">Biome</button>
            <button type ="button" onclick="displayRock()">Rock</button>
            
            <button type ="button" onclick="displayAll()">Default</button> 
            </fieldset>
            <br>
            Zoom Level: <input type="number" id="mapSize" onchange="scaleMap()" value="1">
            
            <hr>
            Teleportation Settings
            <br>
            X: <input type="number" id="xgo"> Y: <input type="number" id="ygo">
            <button type = "button" onclick="teleport()">Go!</button>
            <hr>
            <div>
                <h3>Item Data</h3>
                <a id ="itempropername"></a>
                <br>
                <a id="itemtile"></a>
                <br>
                <a id="itemname"></a>
                <br>
                <a>Mass: </a><a id="itemmass"></a>
                <br>
                <a>Length: </a><a id="itemlength"></a>
                <br>
                <a>Volume: </a><a id="itemvolume"></a>
                <br>
                <a>Value: $</a><a id="itemvalue"></a>
                <br>
                <a>Age: </a><a id="itemage"></a>
                <br>
                <a>Blood volume: </a><a id="itembloodvolume"></a>
                <br>
                <a>Burden: </a><a id="itemburden"></a>
                <br>
                <a>Piercing Power: </a><a id="itempierce"></a>
                <br>
                <a>Slashing Power: </a><a id="itemslash"></a>
                <br>
                <a>Bludgeoning Power: </a><a id="itembludgeon"></a>
                <br>
                <a>Swinging Power: </a><a id="itemswing"></a>
                <br> <a>Inventory: </a>
                <div id="iteminventory"></div>
            </div>
            
        </div>
        <div class="controls">
            <table>
                <tr><td class="outbox" onclick="upkey()"><a class="inbox">w</a> Move Up</td></tr>
                <tr><td class="outbox" onclick="leftkey()"><a class="inbox">a</a> Move Left</td></tr>
                <tr><td class="outbox" onclick="downkey()"><a class="inbox">s</a> Move Down</td></tr>
                <tr><td class="outbox" onclick="rightkey()"><a class="inbox">d</a> Move Right</td></tr>
                <tr><td class="outbox" onclick="gkey()"><a class="inbox">g</a> Swap Items in Hands</td></tr>
                <tr><td class="outbox" onclick="fkey()"><a class="inbox">f</a> Pick Up Left Hand</td></tr>
                <tr><td class="outbox" onclick="hkey()"><a class="inbox">h</a> Pick Up Right Hand</td></tr>
                <tr><td class="outbox" onclick="vkey()"><a class="inbox">v</a> Drop Left Hand</td></tr>
                <tr><td class="outbox" onclick="nkey()"><a class="inbox">n</a> Drop Right Hand</td></tr>
                <tr><td class="outbox" onclick="ekey()"><a class="inbox">e</a> Wear Item</td></tr>
                <tr><td class="outbox" onclick="rkey()"><a class="inbox">r</a> Remove Item</td></tr>
                <tr><td class="outbox" onclick="pkey()"><a class="inbox">p</a> Contain Item</td></tr>
                <tr><td class="outbox" onclick="xkey()"><a class="inbox">x</a> Punch/Stab</td></tr>
                <tr><td class="outbox" onclick="zkey()"><a class="inbox">z</a> Swing/Slash</td></tr>
                <tr><td class="outbox" onclick="ckey()"><a class="inbox">c</a> Craft</td></tr>
                <tr><td class="outbox" onclick="tkey()"><a class="inbox">t</a> Change Speed</td></tr>
                <tr><td class="outbox" onclick="ukey()"><a class="inbox">u</a> Use Item</td></tr>
                <tr><td class="outbox" onclick="kkey()"><a class="inbox">k</a> Start Conversation</td></tr>
            </table><hr>
            <table id = "chatrols"></table>
        </div>
    </div>
