        function tdrcw(a,b) {
            let n = twodorandom(a,b + 0.245);
            let o = twodorandom(a,b + 0.345);
            let p = twodorandom(a,b + 0.445);
            let q = twodorandom(a,b + 0.545);
            return (n+o+p+q)/4;
        }

        function rawPerlin(x, y, gridSize, offset) {
            let newOffset = 10000.0*offset;
            //newOffset = 0;
            return (evenRawer((x + newOffset)/gridSize,(y+newOffset)/gridSize) + 1)/2; //returns a number on between 0 and 1
        }

        function perlinSlopeMagnitude(x, y, gridSize, offset) { //returns a number between 0 and 2sqrt(2)
            let left = rawPerlin (x-1, y, gridSize, offset);
            let right = rawPerlin (x+1, y, gridSize, offset); 
            let up = rawPerlin (x, y+1, gridSize, offset); 
            let down = rawPerlin (x, y-1, gridSize, offset);
            let lr = (right - left)/2;
            let ud = (down-up/2);
            let magnitude = Math.sqrt(lr**2 + ud**2);
            return 2*magnitude;
        }

        function allGensPerlin(x, y, seed) {
            const generations = 12;
            let totalheight = 0;
            for (let i = generations; i > 1; i--) {
                let os = twodorandom(seed, i);
                let grad = perlinSlopeMagnitude(x,y,2**i,os);
                let heighy = (2**i)*(rawPerlin(x,y,2**i,os));
                
                totalheight+= heighy*(1/(1+grad));
            }
            let montanity = (rawPerlin(x,y,2**generations,twodorandom(seed,2.7)));
            return totalheight * montanity;
        }

