            getBludgeonPower(weapon) {
                return (weapon.totalMass * (Math.cbrt(3*this.soul.height*65*20*(this.soul.upperBodyStrength**2)*(1/weapon.totalMass))));
            }

            getPiercePower(weapon) {
                let ret = 0;
                if (weapon.pierces) {
                    ret = this.getBludgeonPower(weapon)/(0.1 * weapon.material.hardness);
                }
                return ret;
            }

            getSwingPower(weapon) {
                let hl = 0;
                if (weapon.hasHandle) {
                    hl = weapon.handleLength;
                }
                return weapon.totalMass * Math.sqrt(2*9.8*((this.soul.height/2)+(hl + (weapon.bladeLength/2))));
            }

            getSlashPower(weapon) {
                let ret = 0;
                if (weapon.slashes) {
                    ret = this.getSwingPower(weapon)/(0.1* weapon.material.hardness);
                }
                return ret;
            }

            die() {
                if (this.isLiving) {
                    this.achieve("Death");
                    gamelog(this.soul.nameToDisplay.concat(" has died."),"#ff0000");
                    this.dropFromHand(0);
                    this.dropFromHand(1);
                    this.isLiving = false;
                    this.givenGenericTitle = this.soul.speceisName.concat(" Corpse");
                    this.soul = undefined;
                    this.calculateSecondaryAttributes();
                }
            }

            getAttackableBodyPart(seed,iter) {
                const possatacks = ["torso","chest"]
                let rand = twodorandom(seed,iter);
                let bp = Math.floor(21 * rand);
                if (this.soul.severed_limbs.includes(bp)) {
                    return getAttackableBodyPart(seed, iter+1);
                } else {
                    return bp;
                }
            }

            attack(target,attacktype) {//0 = punch/stab 1 = swing/slash
                //console.log(target);
                if (!target) {
                    gamelog("No target selected.");
                } else {
                    if (!target.isLiving) {
                        gamelog("Target is not alive.");
                    } else {
                        if (!(Math.abs(this.x - target.x) <= 1 && Math.abs(this.y - target.y) <= 1)) {
                            if (this == player) {
                                gamelog("Target is not in range");
                            } else{
                                this.think();
                            }
                            
                        } else {
                            if (target != player) {
                                target.soul.angery = true;
                                target.soul.angeryAt.push(this);
                                target.think();
                            }
                            let targetname = target.soul.nameToDisplay;
                            let attackername = this.soul.nameToDisplay;
                            let targetpossessive = target.soul.nameToDisplay.concat("'s ");
                            let has = " Has ";
                            if (target === player) {
                                targetpossessive = "Your ";
                                targetname = "You";
                                has = " Have ";
                               
                            } else if (this === player) {
                                attackername = "You";
                            }
                            let xpincrease = (target.totalMass * target.soul.constitution) / ((this.soul.meleeSkill + 1) * this.totalMass);
                            let bodyPartTarget = target.getAttackableBodyPart(twodorandom(currentTime,1.6),0);
                            //console.log(bodyPartTarget);
                            let weapon = this.soul.inHands[1];
                            if (this.soul.disabled_limbs.includes(5) || this.soul.severed_limbs.includes(5)) {
                                weapon = this.soul.inHands[0];
                            }
                            let aText = "";
                            let uText = "";
                            let sexnm = "He";
                            if (this.sex == 1) {
                                sexnm = "She";
                            }
                            let accuracy = 0
                            let bloodmult = 1;
                            if (bodyPartTarget == 0 || bodyPartTarget == 1) {
                                bloodmult = 2;
                            }
                            let weaponmass = 0;
                            let weaponlength = this.soul.height/2;
                            let power = 0;
                            let at2 = 0;
                            let weaponhard = this.material.hardness;
                            if(weapon) {
                                weaponmass = weapon.totalMass;
                                weaponhard = weapon.material.hardness;
                                if (weapon.hasHandle) {
                                    weaponlength += weapon.handleLength;
                                }
                                weaponlength+= weapon.bladeLength;
                            }
                            if (attacktype == 0) {
                                accuracy = (100*twodorandom(currentTime,originalSeed +0.13))+((100*this.soul.upperBodyStrength)/(weaponmass + (0.1 * this.soul.upperBodyStrength * this.soul.relativeHandSize)))+this.soul.meleeSkill;
                            } else {
                                accuracy = (100*twodorandom(currentTime,originalSeed +0.13))+((100*this.soul.upperBodyStrength)/((weaponmass*weaponlength) + (0.1 * this.soul.upperBodyStrength * this.soul.relativeHandSize)))+this.soul.meleeSkill;
                            }
                            
                            if (!weapon) {
                                aText = " punches ";
                                if (this === player) {
                                    aText = " punch ";
                                }
                                uText = " with the fist.";
                                power = (((this.totalMass/10) * this.soul.relativeHandSize) * (Math.cbrt(3*this.soul.height*65*20*(this.soul.upperBodyStrength**2)*((this.totalMass/10) * this.soul.relativeHandSize))));
                            } else{
                                uText = " with the ".concat(weapon.genericName);
                                if (weapon.pierces && attacktype == 0) {
                                    aText = " stabs ";
                                    if (this === player) {
                                    aText = " stab ";
                                }
                                    power = this.getPiercePower(weapon);
                                    at2 = 1;
                                } else if (weapon.slashes && attacktype == 1) {
                                    aText =" slashes ";
                                    if (this === player) {
                                        aText = " slash ";
                                    }
                                    power = this.getSlashPower(weapon);
                                    at2 = 2;
                                } else if (attacktype == 1) {
                                    aText = " bludgeons ";
                                    if (this === player) {
                                        aText = " bludgeon ";
                                    }
                                    power = this.getSwingPower(weapon);
                                    at2 = 3;
                                } else {
                                    aText = " punches ";
                                    if (this === player) {
                                        aText = " punch ";
                                    }
                                    power = this.getBludgeonPower(weapon);
                                    at2=0;
                                }
                            }
                            //now we get to the fun part.
                            gamelog(attackername.concat(aText).concat(targetname).concat(" In the ").concat(bodyPartStrings[bodyPartTarget]).concat(uText),this.getFC());
                            if (at2 == 1) {
                                if (accuracy >= 100) {
                                    let pierces = target.doesItPierce(power,0,weapon,bodyPartTarget);
                                    if (pierces) {
                                        let woundepth = (10* twodorandom(currentTime,0.9813))*(this.soul.meleeSkill + 1) * (0.001);
                                        if (woundepth > weapon.bladeLength) {
                                            woundepth = weapon.bladeLength;
                                        }
                                        
                                        gamelog(targetname.concat(has).concat("been pierced. A wound ").concat(roff(woundepth)).concat(" meters deep has been created."),target.getFC());
                                        target.soul.wounds.push(new wound(bloodmult*(woundepth + (weapon.bladeThickness * weapon.bladeDepth))));
                                        target.getStabbed(bodyPartTarget,woundepth);
                                    } else {
                                        gamelog("The attack does not pierce.",target.getFC())
                                        at2 = 0;
                                    }
                                } else {
                                    gamelog(sexnm.concat(" Misses."),this.getFC());
                                }
                            }
                            if (at2 == 2) {
                                if (accuracy >= 100) {
                                    let pierces = target.doesItPierce(power,0,weapon,bodyPartTarget);
                                    if (pierces) {
                                        let woundepth = (10* twodorandom(currentTime,0.9813))*(this.soul.meleeSkill + 1) * (0.0001);
                                        if (woundepth > weapon.bladeDepth) {
                                            woundepth = weapon.bladeDepth;
                                        }
                                        let woundbreath = (10* twodorandom(currentTime,0.9813))*(this.soul.meleeSkill + 1) * (0.001);
                                        if (woundbreath > weapon.bladeLength) {
                                            woundbreath = weapon.bladeLength;
                                        }
                                        this.achieve("First Slash");
                                        gamelog(targetname.concat(has).concat("been lacerated. A wound ").concat(roff(woundbreath)).concat(" meters long has been created."),target.getFC());
                                        target.soul.wounds.push(new wound(bloodmult*(woundepth + (woundbreath * weapon.bladeThickness))));
                                        target.getStabbed(bodyPartTarget,woundepth);
                                    } else {
                                        gamelog("The attack does not pierce",target.getFC());
                                        at2 = 3;
                                    }
                                } else {
                                    gamelog(sexnm.concat(" Misses."),this.getFC());
                                }
                            }
                            if (at2 == 0 || at2 == 3) {
                                if (accuracy > 100) {
                                    let bonegate = 100 * (twodorandom(currentTime,0.73) + (target.soul.constitution - 0.5));
                                    if (power > bonegate) {
                                        if (!(target.soul.broken_bones.includes(bodyPartTarget))) {
                                            gamelog(targetpossessive.concat(bodyPartStrings[bodyPartTarget]).concat( " bone has been broken."),target.getFC());
                                            target.soul.broken_bones.push(bodyPartTarget);
                                        } else {
                                            gamelog(targetpossessive.concat(bodyPartStrings[bodyPartTarget]).concat( " has been mangled."),target.getFC());
                                            target.mangle(bodyPartTarget);
                                        }
                                        
                                        //actually make that do somethingf
                                    } else {
                                        gamelog("The attack had no effect",target.getFC());
                                    }
                                } else {
                                    gamelog(sexnm.concat(" Misses."),this.getFC());
                                }
                            }
                            if (this == player) {
                                advanceTime(currentTime + this.attackTime(attacktype));
                            }
                            //console.log(target);
                            if (this.soul.meleeSkill < 9000 && this.soul.meleeSkill + xpincrease > 9000) {
                                this.achieve("It's very large, your skill");
                            }
                            this.soul.meleeSkill += xpincrease;
                            
                        }
                    }
                }
            }

            attackTime(attacktype) {//returns amount of time in seconds
                let d = 0;
                let t = 0;
                let a = 0;
                if (this.soul.inHands[1]) {
                    let weapon = this.soul.inHands[1];
                    if (attacktype == 1) {
                        d = (this.soul.height/2)+(weapon.bladeLength/2);
                        a = Math.sqrt(2*9.8*((this.soul.height/2)+((weapon.bladeLength/2))));
                    } else {
                        d = (1);
                        a = (Math.cbrt(3*this.soul.height*65*20*(this.soul.upperBodyStrength**2)*(1/weapon.totalMass)));
                    }
                } else {
                    d = 1;
                    a = (Math.cbrt(3*this.soul.height*65*20*(this.soul.upperBodyStrength**2)*((this.totalMass/10) * this.soul.relativeHandSize)));
                }
                //console.log(d);
                //console.log(a);
                t = Math.sqrt(2*d/a);
                //console.log(t);
                return t;
            }

            swapHands() {
                let holder = this.soul.inHands[0];
                this.soul.inHands[0] = this.soul.inHands[1];
                this.soul.inHands[1] = holder;
            }

            getStabbed(bodypart, depth) {
                if ((depth >= 0.2 && (bodypart === 10 && this.soul.broken_bones.includes(bodypart)))||(depth >= 0.1 && bodypart === 1)||(depth >= 0.05 && (bodypart === 0 && this.soul.broken_bones.includes(bodypart)))) {
                    gamelog(this.soul.nameToDisplay.concat(" Has been stabbed to death."),this.getFC());
                    this.die();
                } else if (bodypart < 2 && depth >= 0.15 * this.soul.relativeBroadness) {
                    gamelog(this.soul.nameToDisplay.concat(" Has been decapitated."),this.getFC());
                    this.die();
                } else if ( (bodypart == 10 || bodypart == 11 ||bodypart == 12)&& depth>=0.3*this.soul.relativeBroadness) {
                    gamelog(this.soul.nameToDisplay.concat(" Has been cut to pieces."),this.getFC());
                    this.die();
                } else if (depth >= 0.075 * this.soul.relativeBroadness) {
                    let bps =bodyPartStrings(bodypart);
                    this.severLimb(bodypart);
                    gamelog(this.soul.nameToDisplay.concat("'s ").concat(bps).concat(" has been severed."),this.getFC());
                }
            }

            severLimb(bodypart) {
                if(!(this.soul.severed_limbs.includes(bodypart))) {
                    this.soul.severed_limbs.push(bodypart);
                    this.achieve("Amputee");
                    if (bodypart == 2) {
                        this.severLimb(6);
                    } else if (bodypart == 3) {
                        this.severLimb(7);
                    } else if (bodypart == 6) {
                        this.severLimb(8);
                    } else if (bodypart == 7) {
                        this.severLimb(9);
                    } else if (bodypart == 8) {
                        this.severLimb(4); 
                    } else if (bodypart == 9) {
                        this.severLimb(5); 
                    } else if (bodypart >= 13 && bodypart <= 18) {
                        this.severLimb(bodypart + 2); 
                    } 
                    
                }
            }

            mangle(bodypart) {
                if(!(this.soul.disabled_limbs.includes(bodypart))) {
                    this.soul.disabled_limbs.push(bodypart);
                    if (bodypart == 2) {
                        this.mangle(6);
                    } else if (bodypart == 3) {
                        this.mangle(7);
                    } else if (bodypart == 6) {
                        this.mangle(8);
                    } else if (bodypart == 7) {
                        this.mangle(9);
                    } else if (bodypart == 8) {
                        this.mangle(4); 
                    } else if (bodypart == 9) {
                        this.mangle(5); 
                    } else if (bodypart >= 13 && bodypart <= 18) {
                        this.mangle(bodypart + 2); 
                    } else if (bodypart ==0 || bodypart == 10) {
                        gamelog(this.soul.nameToDisplay.concat(" has been bludgeoned to death."),this.getFC());
                        this.die();
                    }
                    
                }
            }

            doesItPierce(power,type,weapon,bodypartnum) {
                let returnist = true;
                let finalpower = power;
                if (weapon.material.hardness < this.material.hardness) {
                    returnist = false;
                } else {
                    this.equiped.forEach(element => {
                        if (element.whereArmors === bodypartnum) {
                            if (weapon.material.hardness < element.material.hardness) {
                                finalpower = 0;
                            } else {
                                let effing = element.armorialThickness * element.material.tensileStrength;
                                if (element.isChain) {
                                    effing *= 2/5;
                                }
                                finalpower *= 1/(Math.E**effing);
                            }
                        } 
                    })
                    if (finalpower < this.constitution) {
                        returnist = false;
                    }
                }
                return returnist;
            }

            craft(iter) {
                let tp = getWorld(this.x,this.y);
                if (!tp) {
                    gamelog("Cannot craft while zoomed out.");
                } else {
                    let station = tp.thingsHere[iter];
                    if (station == undefined) {
                        gamelog("There is no crafting station here.");
