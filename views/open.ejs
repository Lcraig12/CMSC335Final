            cov(x,y) {//returns the new xy as an array
                let ret = [0,0]
                //console.log(`${x}, ${y}`);
                //console.log(`${this.cornerx}, ${this.cornery}`);
                if(this.direction == 0 || this.direction == 1) {
                    ret[0] = x + this.cornerx;
                    ret[1] = y + this.cornery;
                } else {
                    ret[0] = this.cornerx -x;
                    ret[1] = this.cornery -y;
                }
                if (this.direction == 1 || this.direction == 3) {
                    let n = ret[0];
                    ret[0] = ret[1];
                    ret[1] = n;
                }
                //console.log(ret);

                return ret;
            }
