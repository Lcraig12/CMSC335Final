            calculateCashOnBody(coin) {
                let ret = 0;
                if (this.givenGenericTitle == coin.givenGenericTitle) {
                    ret = this.stackSize;
                }
                if (this.isLiving) {
                    if (this.soul.inHands[0]) {
                        ret += this.soul.inHands[0].calculateCashOnBody(coin);
                    }
                    if (this.soul.inHands[1]) {
                        ret += this.soul.inHands[1].calculateCashOnBody(coin);
                    }
                }
                if (this.isNucleus) {
                    this.children.forEach((e)=>{
                        ret+= e.calculateCashOnBody(coin);
                    });
                }
                this.inventory.forEach((e)=>{
                    ret+= e.calculateCashOnBody(coin);
