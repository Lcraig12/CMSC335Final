                    }
                } else {
                    if (this.soul.inHands[1] == undefined) {
                        if (this == player) {
                            gamelog("You are not holding anything.");
                        }
                    } else {
                        //console.log(this.soul.inHands[1]);
                        if (iter >= this.soul.inHands[1].powers.length) {
                            //console.log("3759");
                            if (this == player) {
                                //console.log(this.soul.inHands[1]);
                                gamelog("You cannot use any item abilities, or you do not have any.");
