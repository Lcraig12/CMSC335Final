        function advanceTime(targetTime) {
            let oldtime = currentTime;
            if (mapSize == 1) {
                if (Math.floor(targetTime) === Math.floor(oldtime)) {
                    currentTime = targetTime;
                    for (let i = 0; i < actionQueue.length; i++) {
                        if (actionQueue[i].endTime < currentTime) {
                            actionQueue[i].agent.dooo(actionQueue[i]);
                            actionQueue.splice(0,1);
                        } /*else {
                            i = actionQueue.length + 543;//arbitrary, escaping loop
                        }*/
                    }
                } else {
                    currentTime = Math.floor(oldtime + 1);
                    for (let i = 0; i < actionQueue.length; i++) {
                        if (actionQueue[i].endTime < currentTime) {
                            actionQueue[i].agent.dooo(actionQueue[i]);
                            actionQueue.splice(0,1);
                        } /*else {
                            i = actionQueue.length + 543;//arbitrary, escaping loop
                        }*/
                    }
                    secondEvents();
                    advanceTime(targetTime);
                }
            } else {
                currentTime = targetTime;
            }
        }

