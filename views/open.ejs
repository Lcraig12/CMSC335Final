                        if (station.tile == "⋀"){
                            if (this.soul.inHands[0] && this.soul.inHands[1]) {
                                this.soul.inHands[1].powers.forEach((element)=>{
                                    useOnDrop(this,element,this.soul.inHands[1]);
                                });
                                this.soul.inHands[0].powers.forEach((element)=>{
                                    useOnDrop(this,element,this.soul.inHands[0]);
                                });
                                this.soul.inHands[1] = this.and(this.soul.inHands[0],this.soul.inHands[1]);
                                this.soul.inHands[1].powers.forEach((element)=>{
                                    useOnPickUp(this,element,this.soul.inHands[1]);
                                });
                                this.soul.inHands[0] = undefined;
                            } else {
                                gamelog("You are not holding two items to craft.");
                            }
                        } else if (station.tile == "⋁") {
                            if (this.soul.inHands[0] && this.soul.inHands[1]) {
                                this.soul.inHands[1].powers.forEach((element)=>{
                                    useOnDrop(this,element,this.soul.inHands[1]);
                                });
                                this.soul.inHands[0].powers.forEach((element)=>{
                                    useOnDrop(this,element,this.soul.inHands[0]);
                                });
                                this.soul.inHands[1] = this.or(this.soul.inHands[0],this.soul.inHands[1]);
                                this.soul.inHands[1].powers.forEach((element)=>{
                                    useOnPickUp(this,element,this.soul.inHands[1]);
                                });
                                this.soul.inHands[0] = undefined;
                            } else {
                                gamelog("You are not holding two items to craft.");
                            }
                        } else if (station.tile == "⊗") {
                            if (this.soul.inHands[0] && this.soul.inHands[1]) {
                                this.soul.inHands[1].powers.forEach((element)=>{
                                    useOnDrop(this,element,this.soul.inHands[1]);
                                });
                                this.soul.inHands[0].powers.forEach((element)=>{
                                    useOnDrop(this,element,this.soul.inHands[0]);
                                });
                                this.soul.inHands[1] = this.xor(this.soul.inHands[0],this.soul.inHands[1]);
                                this.soul.inHands[1].powers.forEach((element)=>{
                                    useOnPickUp(this,element,this.soul.inHands[1]);
                                });
                                this.soul.inHands[0] = undefined;
                            } else {
                                gamelog("You are not holding two items to craft.");
                            }
                        } else if (station.tile == "🅶") {
                            if (this.soul.inHands[0] && this.soul.inHands[1]) {
                                this.soul.inHands[1] = this.graft(this.soul.inHands[0],this.soul.inHands[1]);
                                this.soul.inHands[0].powers.forEach((element)=>{
                                    useOnDrop(this,element,this.soul.inHands[0]);
                                });
                                this.soul.inHands[0] = undefined;
                            } else {
                                gamelog("You are not holding two items to craft.");
                            }
                        } else if (station.tile == "⛮") {
                            if (!this.soul.inHands[0] && this.soul.inHands[1]) {
                                let k = this.handleremove(this.soul.inHands[1]);
                                this.soul.inHands[1] = k[1];
                                this.soul.inHands[0] = k[0];
                            } else {
                                gamelog("You are not holding an item in your right hand and not in your left.");
                            }
                        } else if (station.tile == "🝥") {
                            if (this.soul.inHands[0] && this.soul.inHands[1]) {
                                this.soul.inHands[1].powers.forEach((element)=>{
                                    useOnDrop(this,element,this.soul.inHands[1]);
                                });
                                this.soul.inHands[0].powers.forEach((element)=>{
                                    useOnDrop(this,element,this.soul.inHands[0]);
                                });
