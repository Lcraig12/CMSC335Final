        function crergba(r, g, b) { //fine
            let rr = Math.floor(r).toString(16);
            let gg = Math.floor(g).toString(16);
            let bb = Math.floor(b).toString(16);
            if (rr.length === 1) {
                rr= "0".concat(rr);
            }
            if (gg.length === 1) {
                gg= "0".concat(gg);
            }
            if (bb.length === 1) {
                bb= "0".concat(bb);
            }
            return "#".concat(rr.concat(gg.concat(bb)));
        }

        function comborgbs(a, b) {
            let r1 = parseInt(a.substring(1,3),16);
            let g1 = parseInt(a.substring(3,5),16);
            let b1 = parseInt(a.substring(5,7),16);
            let r2 = parseInt(b.substring(1,3),16);
            let g2 = parseInt(b.substring(3,5),16);
            let b2 = parseInt(b.substring(5,7),16);
            let rf = (r1+r2)/2;
            let gf = (g1+g2)/2;
            let bf = (b1+b2)/2;
            return crergba(rf,gf,bf);

        }

