            detmoist() { //on a scale of 0 to 128
                //console.log(this.parenty);
                let perlinvalue = rawPerlin(Number(this.x + REGIONSIZE*this.parentx),Number(this.y + REGIONSIZE*this.parenty), Number(2**13),twodorandom(Number(originalSeed),0.514));
                
                this.moisture = ((this.z/(MAXELEV*6))+0.9)*perlinvalue*128.0;
                //console.log(perlinvalue);
            }

            toErrey() {
                let returnist = new Array();
                returnist.push(this.x);
                returnist.push(this.y);
                returnist.push(this.bkgc);
                returnist.push(this.tile);
                returnist.push(this.builtTile);
                returnist.push(this.builtColor);
                returnist.push(this.isSolid);
                let nonnotaray = [];
                this.thingsHere.forEach((e)=>{
                    if(!e.isHistoric) {
                        nonnotaray.push(e);
                    }
                })
                returnist.push(this.nonnotaray);
                return returnist;
            }

            enforceHomeostasis(ntr) {
                //console.log("enforcing homeostasis");
                for (let i = 0; i < this.thingsHere.length; i ++) {
                    this.thingsHere[i].homeostasis(ntr);
                }
                this.detbackolor();
            }
        }

        function roff(numb) {
            let neg = false;
            if (roff < 0) {
                neg = true;
            }
            let h = Math.abs(numb);
            let j = 0;
            while (h < 1000 && h != 0) {
                j++;
                h*=10;
                //console.log(h);
            }
            let ooo =  Math.floor(h)/(10**j);
            if (neg) {
                ooo *= (-1);
            }
            return ooo;
        }

        class region {
            constructor(x, y) {
                this.x = x; //iterative actually lol
                this.y = y;
                this.world = [];
                this.isloaded = false;
                this.file="";
                this.notable= false;
                //console.log("it beginas");
                //console.log(twodorandom(x,y));
                this.localseed = twodorandom(Number(originalSeed),twodorandom(this.x,this.y));
                //console.log(this.localseed);
                this.culture = getIdent(this.x,this.y, Number(originalSeed));
                //cultural things below
                this.isCity = detWhetherCity(x,y,Number(originalSeed));
                this.rockType = detRockType(x,y);
                this.cultureObject = undefined;
