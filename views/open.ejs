        function threedigcomb(a, b){ //combines two ints in six digits ex tdc(4, 12) = 004012
            let x = a.toString();
            let y = b.toString();
            if (x.length === 1) {
                x = ("00").concat(x);
            } else if (x.length === 2) {
                x = ("0").concat(x);
            }
            if (y.length === 1) {
                y = ("00").concat(y);
            } else if (y.length === 2) {
                y = ("0").concat(y);
            }
             
            return x.concat(y);
        }

