        function getFish(climate, skill, seed){
            let propensityToNotFish = 0.0001 * (1 + (30*skill));
            if (twodorandom(seed,0.93)>(1- propensityToNotFish)) {
                let a = randomItem(twodorandom(seed,originalSeed));
                player.achieve("Unusual Catch");
                if (a.powers.includes("fishing")) {
                    player.achieve("Fisher of Fishing Rods");
                }
                return a;
            } else {
                let a = skill * 24;
                let b = (1+skill);
                //console.log("3867");
                let fishList = undefined;
                if (climate >= 96) {
                    fishList = fish_hot;
                } else if (climate >= 64) {
                    fishList = fish_med;
                } else {
                    fishList = fish_cold;
                }
                let fishnumber = 0;
                fishList.forEach((element)=>{
                    fishnumber += ((element.rareness/b)+a);
                });

                let fishdex = fishnumber * twodorandom(currentTime, 0.113623);
                let ret = undefined;

                fishList.forEach((element)=>{
                    if (fishdex <= ((element.rareness/b)+a)) {
                        ret = element;
                        fishdex = fishnumber * 2;
                    } else {
                        fishdex -= ((element.rareness/b)+a);
                    }
                });
                return ret;
            }
        }

        function alloyMaterial(a,b) {
