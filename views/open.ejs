                this.startTime = startTime;
                this.endTime = endTime;
                this.type = type;
                this.direction = direction;
                this.target = target;
            }
        }

        class material {
            constructor(name, density, color, hardness, isRadioactive, halfLife, eRist, ppm, value, meltPt, boilPt, isFlammable, flashPoint, tensile, compressive, edibility) {
                this.name = name;
                this.density = density;
                this.color = color;
                this.hardness = hardness;//moh's hardness scale
                this.isRadioactive = isRadioactive;
                this.halfLife = halfLife;
                this.electricalResistivity = eRist; // in ohm-meters
                this.occurance = ppm; // ppm in the crust.
                this.value = value;//price per kg in $
                this.meltingPoint = meltPt;//kelvin
                this.boilingPoint = boilPt;//kelvin
                this.isFlammable = isFlammable;
                this.flashPoint = flashPoint;//kelvin
                this.tensileStrength = tensile;//kg/m^2
                this.compressiveStrength = compressive;
                this.edibility = edibility;

            }
        }

