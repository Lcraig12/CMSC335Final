        function dWCH(x,y,seed,itr) {//Helper function, DO NOT CALL
            
            let baseProb = 50;
            let paseBrob = 1;
            let fect = Math.abs(x * 64);
            if (fect < 1000000) {
                paseBrob = ((3 * fect)/100000) + 20;
            } else if (fect < 6000000) {
                paseBrob = 50;
            } else if (fect < 10000000) {
                paseBrob = ((247/2) - ((49 * fect)/4000000));
            }
            const maxIters = 1;//this used to be 8. Now it isn't
            const threshold = 0.96;//if it is next to when will it combine
            if (itr >= maxIters) {
                return false;
            } else if (twodorandom(x,twodorandom(y,seed)) <1/(baseProb*(6.28**itr)) && paseBrob + (50 *twodorandom(x+.7456, y+.035)) > 50) {//yes this is 2pi for a reason
                return true;
            } else {
                let ns = twodorandom(seed, itr);
                if (twodorandom(x,twodorandom(y,seed))>threshold && (dWCH(x, y-1, ns, itr+1) || dWCH(x, y+1, ns, itr+1) || dWCH(x-1, y, ns, itr+1) || dWCH(x+1, y, ns, itr+1))) {
                    return true;
                } else {
                    return dWCH(x,y,ns,itr+1);
                }
            }
        }

