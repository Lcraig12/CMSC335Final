            equipFromRightHand() {
                if (this.isLiving) {
                    let irh = this.soul.inHands[1];
                    if (irh && irh.wearable) {
                        if (irh.armorialSize >= this.soul.shoeSize) {
                            this.equiped.push(irh);
                            irh.powers.forEach((element)=>{
                                useOnEquip(this,element,irh);
                            });
                            this.soul.inHands[1].powers.forEach((element)=>{
                                useOnDrop(this,element,this.soul.inHands[1]);
                            });
                            this.soul.inHands[1] = undefined;

                        } else {
                            if(this==player) {
                                gamelog("You cannot equip that because it is too small to fit on you.",this.getFC());
                            }
                        }
                        
                    } else {
                        if(this==player) {
                            gamelog("You are not holding anything wearable.",this.getFC());
                        }
                    }
                }

            }

            deEquipToRightHand(item, itemparent) {
                if(itemparent && this.isLiving && this.soul.inHands[1] == undefined) {
                    //let inventoryness = 1;
                    let j = itemparent.inventory.indexOf(item);
                    if (j == -1) {
                        let k = itemparent.equiped.indexOf(item);
                        if(k != -1) {
                            this.soul.inHands[1] = item;
                            this.soul.inHands[1].powers.forEach((element)=>{
                                useOnPickUp(this,element,this.soul.inHands[1]);
                            });
                            item.powers.forEach((element)=>{
                                useOnDequip(this,element,item);
                            });
                            itemparent.equiped.splice(k,1);
                        } else {
                            console.error(`Error: Item ${item} is not in inventory of context ${itemparent}`);
                            console.log(item);
                            console.log(itemparent);
                            
                        }
                    } else {
                        this.soul.inHands[1] = item;
                        this.soul.inHands[1].powers.forEach((element)=>{
                            useOnPickUp(this,element,this.soul.inHands[1]);
                        });
                        
                        itemparent.inventory.splice(j,1);
                    }
                }

            }

