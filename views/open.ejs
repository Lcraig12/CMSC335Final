        class soul {
            constructor() {
                this.speceisName = "";
                this.name = [];
                this.sex = 0; // 0 for male, 1 for female.
                this.upperBodyStrength = 1;//relative
                this.skinTone = 1;//relative
                this.eyeSight = 1;//somewhat abstract, score for total eyesight efficacy, regardless of number of eyes
                this.legCount = 2;
                this.armCount = 2;
                this.relativeLegLength = 1;//all of these are 1 at their median
                this.relativeHandSize = 1;
                this.relativeFootSize = 1;
                this.lowerBodyStrength = 1;//relative
                this.height = 1.75;
                this.heft = 1; //how fat thou art, relative
                this.flexibility = 1;//relative
                this.coreStrength = 1;//relative
                this.relativeBroadness = 1;
                this.analyticInt = 1;//relative
                this.emotionalInt = 1;//relative
                this.reverence = 1;//relative
                this.aerobicStamina = 1;//relative
                this.anaerobicStamina = 1;//relative
                this.constitution = 1;//relative, also its effect is scaled by things like mass and such
                this.inHands = [];//0 = left, 1 = right. Remember that equipt things apply to the body and not the soul.
                this.amountAerobicUsed = 0;
                this.amountAnaerobicUsed = 0;
                this.hairstyle = "";
                this.favoriteColor = "";
                this.birthSecond = -800000000;

                //these are all not final
                this.nameToDisplay = "";
                this.mass = 0;
                this.bloodVolumeMax = 0;
                this.runInterval = 0;
                this.walkInterval = 0;
                this.sprintInterval = 0;
                this.travelMode = 0;
                this.maxSprintTime = 0;
                this.maxRunTime = 0;
                this.carryingCapacity = 0;
                this.meleeSkill = 0;

                this.wounds = [];
                this.bloodVolumeCurrent = 0;
                this.broken_bones = [];
                this.disabled_limbs = [];
                this.severed_limbs = [];
                this.angery = false;
                this.angeryAt = []; 

                this.recalculateSecondaryAttributes();
            }

            recalculateSecondaryAttributes() {//called after one of the primary attributes changes
                this.nameToDisplay = "";
                for (let i = 0; i < this.name.length; i++) {
                    if(i > 0) {
                        this.nameToDisplay = this.nameToDisplay.concat(" ");
                    }
                    this.nameToDisplay = this.nameToDisplay.concat(this.name[i]);
                }
                //console.log(this.name);
                //console.log(this.nameToDisplay);

                this.mass = ((this.relativeBroadness)**2) * ((this.height)/1.75) * ((this.upperBodyStrength/6) + (this.lowerBodyStrength/20) + (this.coreStrength/20) + (this.heft)) * 60;
                this.bloodVolumeMax = this.mass*0.00007;//in m^3
                this.bloodVolumeCurrent = this.bloodVolumeMax;
                this.shoeSize = ((80*this.height)/3) -36;
                this.runInterval = ((this.mass)/(400*this.lowerBodyStrength));//the time it takes to travel 1 meter while running;
                this.sprintInterval = (1/((1/this.runInterval) + 50 * (this.upperBodyStrength + this.lowerBodyStrength)));//the time it takes to travel 1 meter while sprinting
                this.walkInterval = this.sprintInterval * (5/2)/(this.relativeLegLength * this.analyticInt);//the smarter you are the faster you walk.
                this.maxSprintTime = 20*this.anaerobicStamina;
                this.maxRunTime = 3000*this.aerobicStamina;
                this.carryingCapacity = ((100/175) * this.upperBodyStrength * this.mass) - (this.mass - (((this.relativeBroadness)**2) * ((this.height)/1.75) * 60)) + this.mass/3;
            }

        }

