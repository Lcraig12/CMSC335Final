        function makeColorOutOf(color) {
            let whitefactor = 2-color;
            let blackfactor = color;
            let r = ((whitefactor * 255) + (blackfactor * 61))/2;
            let g = ((whitefactor * 244) + (blackfactor * 40))/2;
            let b = ((whitefactor * 224) + (blackfactor * 30))/2;
            return crergba(r,g,b);
        }

