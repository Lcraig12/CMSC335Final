            loadSelf() {
                //
                if (!this.isloaded) {
                    this.world = new Array();
                    let minx = this.x * REGIONSIZE;
                    let maxx = minx + REGIONSIZE;
                    let miny = this.y * REGIONSIZE;
                    let maxy = miny + REGIONSIZE;
                    let histhingsInReg = [];//this is going to be an ugly array to get, but its quicker to go through it once than several times.
                    historicThingVec.forEach((e)=>{//yeah this is bad, but we only have to do it once per region load. This could be more efficient as an k-d tree but I don't feel like it.
                        if ((e.x >= minx)&&(e.x < maxx)&&(e.y >= miny)&&(e.y < maxy)){//is in the area
                            histhingsInReg.push(e);
                        }
                    });
                    
                    for(let i = 0; i < REGIONSIZE; i++) {
                        this.world[i] = new Array();
                        for(let j = 0; j < REGIONSIZE; j++) {
                            //initialize each pixel
                            this.world[i][j] = new toothpick(i,j,this, this.x, this.y, this.localseed, this.culture);
                            //give them height and stuff
                            
                            
                        }
                    }

                    if(this.file){
                        let k = JSON.parse(this.file);
                        for (let i = 0; i < k.length; i++) {
                            let curobj = k[i];
                            let toobj = this.world[curobj[0]][curobj[1]];
                            toobj.bkgc =curobj[2];
                            toobj.tile=curobj[3];
                            toobj.builtTile=curobj[4];
                            toobj.builtColor=curobj[5];
                            toobj.isSolid = curobj[6];
                            toobj.thingsHere = curobj[7];
                            toobj.notable=true; //the fact that we are loading it indicates that it is notable
                        }
                    }
                    histhingsInReg.forEach((e)=>{//this is the part of the code where the world is populated with historic things
                        //console.log(e);
                        //console.log(e.x - (REGIONSIZE * this.x));
                        //console.log(e.y - (REGIONSIZE * this.y));
                        this.world[e.x - (REGIONSIZE * this.x)][e.y - (REGIONSIZE * this.y)].thingsHere.push(e);
                        //console.log("Putting down the");
                        //console.log(e);
                        this.world[e.x - (REGIONSIZE * this.x)][e.y - (REGIONSIZE * this.y)].thingsHere.sort(function(a,b){return b.bladeLength - a.bladeLength});
                    });
                }
                this.isloaded=true;
            }

            UnloadSelf(){
                let wurield = new Array();
                for(let i = 0; i < REGIONSIZE; i++) {
                    for(let j = 0; j < REGIONSIZE; j++) {

                        if(this.world && (this.world[i][j].notable || this.world[i][j].jbpt)) {
                            wurield.push(this.world[i][j].toErrey());
                        }
                    }
                }
                this.file = wurield;
                this.world = null;
                this.isloaded = false;
            }

            vomitSelf() {
                UnloadSelf();
                let returnist = new Array();
                returnist.push(this.x);
                returnist.push(this.y);
                returnist.push(this.file);
                return returnist;
            }

            doBackGroundColorChange() {
