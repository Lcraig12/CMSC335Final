        function ensureCorrectLoads() {//finished
            //console.log("ecls");
            let bigx = Math.floor(playerx/REGIONSIZE);
            let bigy = Math.floor(playery/REGIONSIZE);
            
            for (let i = 0; i < loads.length; i++) {
                if (Math.abs(loads[i].x - bigx) > 1 || Math.abs(loads[i].y - bigy) > 1) {
                    loads[i].UnloadSelf();
                    loads.splice(i,1);
                } 
            }
            //now to add new stuff
            const scaling = 1;
            for (let k = bigx -scaling; k <= bigx +scaling; k++) {
                for (let l = bigy -scaling; l <= bigy +scaling; l++) {
                    let found = false;
                    for (let j = 0; j < exists.length; j++) {
                        if (exists[j].x === k && exists[j].y === l) {
                            found = true;
                            if (!exists[j].isloaded) {
                                exists[j].loadSelf();
                                loads.push(exists[j]);
                            }
                        }
                    }
                    if (!found) {
                        let a = new region(k,l);
                        a.loadSelf();
                        exists.push(a);
                        loads.push(a);
                    }
                }
            }
            if (Math.abs(playerx) > 10000000) {
                player.achieve("Watch onesself become the traveler from the antique land");
            }
            if (currentTime > 2744000000) {
                player.achieve("Shelf-Stable");
            }
            cullRegions();
            //document.getElementById("debug").innerHTML=getLoadsString();
            ensureCorrectCultures();
            //add call to build tiles here.
            //okay doing that right now
            //here it comes
            loads.forEach((element)=>{
                let ex = element.x - element.cultureObject.x;
                let ey = element.y - element.cultureObject.y;

                let u = element.cultureObject.otherTiles[ex][ey];
                if (!u.unfolded) {
                    u.unfold();
                    element.doHomeostasis(true);
                }
            });
        }

        function ensureCorrectCultures() {
            //zeroth we figure out the ones that need to be loaded
            let nd = [];
            loads.forEach((element)=>{
                nd.push(element.culture);
            });
            //first we remove the extraneous ones.
            for(let i = 0; i < loadedCultures.length; i++) {
                if(!nd.includes(loadedCultureNums[i])) {
                    loadedCultureNums.splice(i,1);
                    loadedCultures.splice(i,1);
                    i--;
                }
            }
            //second we add the new ones


            loads.forEach((element)=> {
                let o = element.culture;
                let n2d = true;
                loadedCultures.forEach((c)=> {
                    if (c.culture == o && c.enumx == Math.floor(element.x/32) && c.enumy == (Math.floor(element.y/32))) {
                        element.cultureObject = c;
                        n2d = false;
                    } 
                    
                });
                if (n2d) {
                    let n = new cultobj(o,Math.floor(element.x/32) * 32,Math.floor(element.y/32) * 32)
                    loadedCultures.push(n);
                    loadedCultureNums.push(o);
                    //just for courtesy, giving it a reference
                    element.cultureObject = n;
                }
            });

        }

