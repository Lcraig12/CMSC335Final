            quitConversation() {
                this.giveGoodbye(this.conversationPartner);
                this.conversationPartner.giveGoodbye(this);
                this.conversationPartner = undefined;
                talkDisplay([]);
            }

            noUnderLayers(item) {
                //returns true if any of the places covered by the item are the only armors in that location.
                if (this.equiped.includes(item)) {
                    let worenums = [];
                    this.equiped.forEach((e)=>{
                        e.whereArmors.forEach((f)=>{
                            if (worenums[f] == undefined) {
                                worenums[f] = 1;
                            } else {
                                worenums[f]++;
                            }
                        });
                    });
                    let ret = false;
                    item.whereArmors.forEach((n)=>{
                        if (worenums[n] == 1) {
                            ret = true;
                        }
                    });
                    return ret;
                } else {
                    return false;
                }
            }

