                p.soul.reverence = df.soul.reverence * (twodorandom(sd,0.2274) + twodorandom(sd,0.21087631));
                p.soul.aerobicStamina = df.soul.aerobicStamina * (twodorandom(sd,0.2434) + twodorandom(sd,0.21181));
                p.soul.anaerobicStamina = df.soul.anaerobicStamina * (twodorandom(sd,5.5732) + twodorandom(sd,0.2104381));
                p.soul.constitution = df.soul.constitution * (twodorandom(sd,0.2434) + twodorandom(sd,0.25531081));
                
                p.soul.hairstyle = df.soul.hairstyle;
                if (!p.soul.hairstyle) {
                    p.soul.hairstyle = hairstyles[Math.floor(hairstyles.length * twodorandom(sd,0.22))];
                }
                p.soul.favoriteColor = crergba(256*twodorandom(sd,0.41),256*twodorandom(sd,0.42),256*twodorandom(sd,0.43));
                p.soul.birthSecond = df.soul.birthSecond * twodorandom(sd,0.21);
                p.soul.recalculateSecondaryAttributes();
            }
            p.bladeDepth = df.bladeDepth * (twodorandom(sd,0.3)+twodorandom(sd,0.7));
            p.bladeThickness = df.bladeThickness * (twodorandom(sd,0.4)+twodorandom(sd,0.8));
            p.bladeLength = df.bladeLength * (twodorandom(sd,0.5)+twodorandom(sd,0.9));
            p.costMultiplier = df.costMultiplier * (twodorandom(sd,0.624)+twodorandom(sd,0.135));
            p.capacity = df.capacity * (twodorandom(sd,0.2124)+twodorandom(sd,0.3135));
            p.material = df.material;
            p.rareness = df.rareness * (twodorandom(sd,0.2624)+twodorandom(sd,0.5135));
            p.hasHandle = df.hasHandle;
            if (p.hasHandle) {
                p.handleLength = df.handleLength * (twodorandom(sd,0.56624)+twodorandom(sd,0.353135));
                p.handleRadius = df.handleRadius * (twodorandom(sd,0.327624)+twodorandom(sd,0.113135));
                p.handleMaterial = df.handleMaterial;
            }
            p.slashes = df.slashes;
            p.pierces = df.pierces;
            p.addlVolume= df.addlVolume * (twodorandom(sd,0.1123624)+twodorandom(sd,0.864135));
            p.isNucleus = df.isNucleus;
            p.children = df.children;
            p.wearable = df.wearable;
            if(p.wearable) {
                p.whereArmors = df.whereArmors;
                p.armorialThickness = df.armorialThickness * (twodorandom(sd,0.446624)+twodorandom(sd,0.25135));
                p.armorialSize = df.armorialSize * (twodorandom(sd,0.2222624)+twodorandom(sd,0.764135));
            }
            p.isChain = df.isChain;
            //here is where we put all the special rules
            if (df.givenGenericTitle === "Bed"){ 
                //we could randomize the bedframe but I'm too tired rn
                p.children =[createThingFromDefault(allThingsDefault.matress,sd)];
                //console.log(p);
            }
            //
            p.tile = df.tile;
            p.givenGenericTitle = df.givenGenericTitle;
            //console.log(df);
            //console.log(df.powers);
            p.powers = structuredClone(df.powers);
            //console.log(p.powers);
            p.calculateSecondaryAttributes();
            //console.log(p);
            return p;

        }

        class thing {
            constructor() {
                //all values are in meters unless otherwise stated.
                this.isHistoric = false;
                this.isLiving = false;
                this.soul = undefined;
                this.capacity = 0; // in m^3
                this.givenGenericTitle = "Thing";

                this.tile = "";
                this.totalMass = 0; //calculated secondarily, includes child items, kg//includes children. excludes inventory
                this.nonHandleMass = 0;//secondariy
                this.rareness = 0.1;//how often relative to other things of the same "type"

                this.hasHandle = false;
                this.handleMass = 0;//secondariy
                this.handleLength = 0;//meters
                this.handleRadius = 0;
                this.handleMaterial = undefined;

                this.genericName = "";//calculated secondarily

                this.slashes = false;
                this.pierces = false;
                this.bladeDepth = 0;//blade is a general name for the head/main part of any item.
                this.bladeThickness = 0;
                this.bladeLength = 0;

                this.addlVolume = 0;//m^3
                this.costMultiplier = 1;//how many times more that the value of its materials is it worth
                this.material = allMaterials.oak; //change to be a default material at some point//ntp
                //who am i kidding, oak is the default material

                this.isNucleus = false;//true if this item has other items attached to it
                this.children = [];//top,bottom,north,east,south,west in that order
                
                this.wearable = false;
                this.whereArmors = [];//0head,1neck,2shoulderleft,3shoulderright,4handleft,5handright,6upperarmleft,7upperarmright,8forearmleft,9forearmright
                //10chest,11abdomen,12waist,13thighleft,14thighright,15kneeleft,16kneeright,17calfleft,18clafright,19footleft,20footright.
                this.armorialThickness = 0;
                this.armorialSize = 10.667;//works on the same scale as U.S. shoe sizes.

                this.isChain = false;

                //mutable properties
                this.totalVolume = 0;
                this.totalValue = 0;
                this.inventory = [];
                this.equiped = [];
                this.isWet = false;
                this.x = 0;
                this.y = 0;
                this.state = 0; //solid = 0, liquid = 1, gas = 2
                this.burden = 0;
                this.taskCount = 0;
                this.stackSize = 1;

                this.powers = []; //string containing all the thing's special abilities
                this.effects = [];//aka status effects, buffs/debuffs syndromes ect

                this.calculateSecondaryAttributes();


            }

            calculateSecondaryAttributes() {
                //calculating mass
                this.totalVolume=0;
                if (this.hasHandle) {
                    this.totalVolume = this.stackSize * this.handleLength * Math.PI * (this.handleRadius ** 2);
                    this.handleMass = this.stackSize * this.handleLength * Math.PI * (this.handleRadius ** 2) * this.handleMaterial.density;
                }
                //calculating armorsurfacearea
                let totalas = 0;
                //console.log(this.nonHandleMass);
                for (let i = 0; i < this.whereArmors.length && this.wearable == true; i++) {
                    let as = armorSurfaceAreas[i] * ((10.667/this.armorialSize) **2);
                    totalas += as;
                }

                let otherVolume = this.stackSize*(((totalas??0) * (this.armorialThickness??0)) + (this.addlVolume??0) + (this.bladeDepth*this.bladeLength*this.bladeThickness));
                
                //console.log(this.material);
                this.totalVolume += otherVolume;
                if (this.totalVolume == NaN) {
                    console.error("Error: thing has NaN volume");
                    console.log(this);
                }
                this.nonHandleMass = otherVolume * this.material.density;
                if (this.isChain) {
                    this.nonHandleMass = this.nonHandleMass/4;
                    //console.log(this.nonHandleMass);
                }
                if (this.isNucleus) {
                    for (let i = 0; i < this.children.length; i++) {
                        this.children[i].calculateSecondaryAttributes();
                        this.nonHandleMass+=this.children[i].totalMass;
                    }
                }
                if (this.isLiving) {
                    this.nonHandleMass = this.soul.mass;
                    this.bladeDepth = this.soul.relativeBroadness * 0.3;
                    this.bladeThickness = this.soul.relativeBroadness * 0.15;
                    this.bladeLength = this.soul.height;
                }
                this.totalMass = this.handleMass + this.nonHandleMass;

                //
                let subval  = 0;
                if (this.hasHandle) {
                    let subval = this.handleMass * this.handleMaterial.value;
                }
                this.totalValue = ((subval)+(this.nonHandleMass * this.material.value))*this.costMultiplier;
                //calculating name generic
                if(this.isLiving) {
                    this.genericName = this.soul.speceisName;
                    let sexname = "Male ";
                    if(this.soul.sex == 1) {
                        sexname = "Female ";
                    }
                    this.genericName = sexname.concat(this.genericName);
                } else {
                    if ( this.givenGenericTitle == "Thing") {
                        if (this.wearable && this.whereArmors.length == 1) {
                            this.givenGenericTitle = armorStrings[this.whereArmors[0]];
                        }
                    }
                    this.genericName = this.givenGenericTitle;
                }
                if (!this.isLiving || this.material!= allMaterials.flesh) {
                    this.genericName = this.material.name.concat(" ").concat(this.genericName);
                }
                
                if (this.isChain) {
                    this.genericName = "Chain ".concat(this.genericName);
                }
                if (this.magic) {
                    this.genericName = "Magic ".concat(this.genericName);
                }

                if (this.wearable) {
                    this.genericName = "Wearable ".concat(this.genericName);
                }
                if (this.hasHandle) {
                    //console.log(this.handleMaterial);
                    
                    this.genericName = this.handleMaterial.name.concat("-handled ").concat(this.genericName);
                }
                if (this.slashes) {
                    this.genericName = "Sharp ".concat(this.genericName);
                }
                if (this.pierces) {
                    this.genericName = "Pointy ".concat(this.genericName);
                }
                if (this.isWet) {
                    this.genericName = "Wet ".concat(this.genericName);
                }
                if (this.stackSize != 1) {
                    this.genericName = this.stackSize.toString().concat(" ").concat(this.genericName).concat("s");
                }
                
                if (this.tile == false) {
                    
                    this.tile = "?";
                }
                //calculating burden
                this.burden = 0;
                if (this.isLiving) {
                    if (this.soul.inHands[1]) {
                        this.burden += this.soul.inHands[1].totalMass + this.soul.inHands[1].burden;
                    }
                    if (this.soul.inHands[0]) {
                        this.burden += this.soul.inHands[0].totalMass + this.soul.inHands[0].burden;
                    }
                }
                this.inventory.forEach(element => {
                    this.burden += element.totalMass + element.burden;
                })
                this.equiped.forEach(element => {
                    this.burden += element.totalMass + element.burden;
                })
            }

            moveTo(tox,toy) {
                if(getWorld(this.x,this.y)) {
                    //console.log("mf");
                    //console.log(getWorld(this.x,this.y).thingsHere);
                    let mf = getWorld(this.x,this.y)
                    let ie = mf.thingsHere.indexOf(this);
                    if (mf.notable == false) {
                        if (!(mf.jbpt == true)) {
                            mf.notable = true;
                        }
                    }
                    mf.jbpt = false;
                    if (!this.isHistoric){
                        historicThingVec.push(this);
                        this.isHistoric = true;
                    }
                    //console.log(ie);
                    mf.thingsHere.splice(ie, 1);
                    mf.detTile();
                    //console.log(getWorld(this.x,this.y).thingsHere);
                }
                this.x = tox;
                this.y = toy;
                if (this.soul.travelMode == 1) {
                    this.soul.amountAerobicUsed+=(this.soul.runInterval/3000);
                } else if (this.soul.travelMode == 2) {
                    this.soul.amountAnaerobicUsed+=(this.soul.sprintInterval/20);
                }
                if (getWorld(tox,toy)) {
                    //console.log("mt");
                    let mt = getWorld(tox,toy);
                    mt.thingsHere.push(this);
                    mt.thingsHere.sort(function(a,b){return b.bladeLength - a.bladeLength});
                    mt.jbpt = true;
                    //console.log(tox);
                    //console.log(toy);
                    //console.log(getWorld(tox,toy).thingsHere);
                    mt.detTile();
                }
            }

            toErrey() {
                let h = JSON.stringify(this);
                
                return h;
            }

            evaporate() {
                gamelog("The ".concat(this.genericName).concat(" has evaporated."),this.material.color)
                this.state = 2;
                this.givenGenericTitle = "Cloud";
                this.pierces = false;
                this.slashes = false;
                this.isChain = false;
                this.tile="☁️";
                this.isWet = false;
                let totalas = 0;
                for (let i = 0; i < this.whereArmors.length; i++) {
                    let as = armorSurfaceAreas[i] * ((10.667/this.armorialSize) **2);
                    totalas += as;
                }
                let otherVolume = (totalas * this.armorialThickness) + this.addlVolume + (this.bladeDepth*this.bladeLength*this.bladeThickness);
                let f = Math.cbrt(otherVolume);
                this.wearable = false;
                this.whereArmors = [];
                this.armorialThickness = 0;
                this.addlVolume = 0;
                this.bladeDepth = f;
                this.bladeLength = f;
                this.bladeThickness = f;
            }

            solidify() {
                gamelog("The ".concat(this.genericName).concat(" has solidified."),this.material.color)
                this.state = 0;
                this.givenGenericTitle = "Lump";
                this.isWet = false;
                this.tile = "🕋"
                this.calculateSecondaryAttributes();
            }

            liquify() {
                gamelog("The ".concat(this.genericName).concat(" has turned to liquid."),this.material.color)
                this.state = 1;
                this.givenGenericTitle = "Glob";
                this.pierces = false;
                this.slashes = false;
                this.isChain = false;
                this.isWet = true;
                this.tile = "💧"
                let totalas = 0;
                for (let i = 0; i < this.whereArmors.length; i++) {
                    let as = armorSurfaceAreas[i] * ((10.667/this.armorialSize) **2);
                    totalas += as;
                }
                let otherVolume = (totalas * this.armorialThickness) + this.addlVolume + (this.bladeDepth*this.bladeLength*this.bladeThickness);
                let f = Math.cbrt(otherVolume);
                this.wearable = false;
                this.whereArmors = [];
                this.armorialThickness = 0;
                this.addlVolume = 0;
                this.bladeDepth = f;
                this.bladeLength = f;
                this.bladeThickness = f;
            }

            homeostasis(necessarytorec) {
                let changesMade = false;
                //console.log("hom");
                //children and other assc items.
                this.children.forEach(element=>{
                    element.homeostasis(necessarytorec);
                })
                this.inventory.forEach(element=>{
                    element.homeostasis(necessarytorec);
                })
                this.equiped.forEach(element=>{
                    element.homeostasis(necessarytorec);
                })
                if (this.isLiving) {
                    this.soul.inHands.forEach(element=>{
                        if (element){
                        element.homeostasis(necessarytorec);}
                    })
                }
                if (this.material.isRadioactive) {
                    let hlm = (0.5)**(SECINTERVAL/this.material.halfLife);
                    this.armorialThickness *=hlm;
                    this.bladeThickness *=hlm;
                    this.addlVolume *=hlm;
                    changesMade = true;
                }

                //change state
                //console.log(curTemp);
                //console.log(this.material.boilingPoint);
                if (curTemp > this.material.boilingPoint && this.state !=2) {
                    this.evaporate();
                    
                    //console.log("Now Gasify!");
                    //evaporate
                } else if (curTemp > this.material.meltingPoint && curTemp < this.material.boilingPoint && this.state !=1) {
                    this.liquify();
                   
                    //console.log("Now Liquify!");
                    //liquify
                } else if (curTemp < this.material.meltingPoint && this.state !=0) {
                    //solidify
                    this.solidify();
                 
                }

                //blood things
                if (this.isLiving) {
                    if (this.soul.bloodVolumeCurrent < this.soul.bloodVolumeMax) {
                        this.soul.bloodVolumeCurrent += (SECINTERVAL *this.soul.bloodVolumeMax/1728000);
                        if (this.soul.bloodVolumeCurrent * this.soul.constitution < 0.6 * this.soul.bloodVolumeMax) {
                            gamelog(this.soul.nameToDisplay.concat(" Has bled out."),"#ff0000");
                            this.die();
                            changesMade = true;
                        }
                    }
                    //wound things
                    if (this.isLiving) {// it might have just died. rip.
                        for (let i = 0; i < this.soul.wounds.length; i++) {
                            changesMade = true;
                            if (twodorandom(currentTime,123) >(1- (0.2 * SECINTERVAL)) && twodorandom(currentTime,235) + (this.soul.constitution/3) >= (1 - (0.01 * SECINTERVAL))) {
                                this.soul.wounds.pop();// it doesn't really matter which ones we pop.
                                i--;
                            }
                        }
                        this.soul.wounds.forEach(element => {
                            this.soul.bloodVolumeCurrent -= (element.effectiveSize * 0.0001 * SECINTERVAL);//some serious dimensional analysis was required to arrive at this number.
                        })

                        //stamina things
                        if (this.soul.amountAerobicUsed > 0) {
                            this.soul.amountAerobicUsed -= (SECINTERVAL * this.soul.constitution/8640);
                        }
                        if (this.soul.amountAnaerobicUsed > 0) {
                            this.soul.amountAnaerobicUsed -= (SECINTERVAL * this.soul.constitution/86400);
                        }
                        if (this.soul.travelMode != 0 && (this.soul.amountAerobicUsed > this.soul.aerobicStamina || this.soul.amountAnaerobicUsed > this.soul.anaerobicStamina)) {
                            this.soul.travelMode = 0;
                            if (this == player) {
                                gamelog("You can no longer run because you have run out of stamina",this.getFC());
                            }
                        }
                        //holding things with broken arms or whaterver
                        if (this.soul.inHands[0] && (this.soul.disabled_limbs.includes(4) || this.soul.severed_limbs.includes(4))) {
                            let stringg = " because your left hand is disabled.";
                            if (this.soul.severed_limbs.includes(4)) {
                                stringg = " because you have no left hand";
                            }
                            gamelog("You drop the ".concat(this.soul.inHands[0].genericName).concat(stringg),this.getFC());
                            this.dropFromHand(0);
                        }
                        if (this.soul.inHands[1] && (this.soul.disabled_limbs.includes(5) || this.soul.severed_limbs.includes(5))) {
                            let stringg = " because your right hand is disabled.";
                            if (this.soul.severed_limbs.includes(5)) {
                                stringg = " because you have no right hand";
                            }
                            gamelog("You drop the ".concat(this.soul.inHands[1].genericName).concat(stringg),this.getFC());
                            this.dropFromHand(1);
                        }
                        if (aboutToSave == 1) {
                            this.angery = false;
                            this.angeryAt = [];
                            this.purchaseqip = undefined;
                            this.purchaseItem = undefined;
                        }
                        if (this.taskCount <= 0) {
                            this.think();
                        }
                    }
                    
                }
                //
                for (let i = 0; i < this.effects.length; i++) {
                    let fet = this.effects[i]
                    if (fet.endTime + fet.timeOfPush > currentTime) {
                        changesMade = true;
                        this.removeEffect(fet.name);
                        i--;
                    } else {
                        fet.doOnHomeostasis(this);
                    }
                }
                if (changesMade || necessarytorec == true){
                    this.calculateSecondaryAttributes();
                }

               
            }

            think() {
                if (this.soul && this.soul.angery) {
                    if (this.soul.angeryAt.length == 0) {
                        this.soul.angery = false;
                    } else {
                                            //console.log("about to attempt");
                        let h = this.attemptToAttack(0);//this will do any in range
                        if (!h) {
                            //console.log("attempt unsuccesful, moving");
                            if (this.soul.angeryAt.length == 0) {
                                this.soul.angery = false;//this might have changed
                            } else {
                                let dir = 3;
                                let xmag = Math.abs(this.soul.angeryAt[0].x - this.x);
                                let ymag = Math.abs(this.soul.angeryAt[0].y - this.y);
                                if (this.soul.angeryAt[0].x > this.x && xmag > ymag) {
                                    dir = 0;

                                } else if (this.soul.angeryAt[0].x < this.x && xmag > ymag) {
                                    dir = 1;
                                } else if (this.soul.angeryAt[0].y > this.y) {
                                    dir = 2;
                                }
                                let time = 0;
                                if (this.soul.travelMode == 0) {
                                    time = this.soul.walkInterval;
                                } else if (this.soul.travelMode == 1) {
                                    time = this.soul.runInterval;
                                } else {
                                    time = this.soul.sprintInterval;
                                }
                                            //console.log("Walking");
                                this.taskCount++;
                                actionQueue.push(new action(this,currentTime,currentTime + time, 1, dir, undefined));
                                            //goingt to do iit
                            }
                        }
                    }
                }
            }

            attemptToAttack(itr) {
                let returnist = false;
                if (this.soul.angeryAt.length <= itr) {
                    // do nothing
                } else if (!this.soul.angeryAt[itr] || !this.soul.angeryAt[itr].isLiving) {
                    this.soul.angeryAt.splice(itr,1);
                    returnist = this.attemptToAttack(itr);
                } else if ((Math.abs(this.soul.angeryAt[itr].x - this.x))>1 || (Math.abs(this.soul.angeryAt[itr].y - this.y))>1) {
                    returnist = this.attemptToAttack(itr + 1);
                } else {
                    returnist = true;
                    this.taskCount++;
                    actionQueue.push(new action(this,currentTime,currentTime + this.attackTime(0),0,undefined,this.soul.angeryAt[itr]));
                }
                return returnist;
            }

            pickUpWithHand(hand, attempt) {
                
                if(this.soul.inHands[hand] == undefined) {
                    let tp = getWorld(playerx,playery);
                    if (tp) {
                        //tp.notable = true;
                        let target = tp.thingsHere[attempt];
                        if (target == this || (target && target.totalMass > this.soul.carryingCapacity - this.burden)) {
                            let joseph = false;
                            if(target.inventory && target.inventory.length > 0){
                                joseph = this.tryPickOut(hand,0,target);
                            }
                            if (!joseph) {
                                this.pickUpWithHand(hand,attempt + 1);
                            }
                        } else if(target) {
                            tp.notable = true;
                            target.getPickedUp();
                            this.soul.inHands[hand] = target;
                            if (target.value > player.value) {
                                this.achieve("Be Careful with That");
                            }
                            if (target.material.name === "ivory") {
                                this.achieve("If I were Paul McCartney, Where would I be hiding?");
                            }
                            target.powers.forEach((element)=>{
                                useOnPickUp(this,element,target);
                                if (element === "fishing") {
                                    player.achieve("Rod-Grasper");
                                }
                            });
                            tp.thingsHere.splice(attempt,1);
                            
                        } else {
                            gamelog("There is nothing here that you can pick up.",this.getFC())
                            
                        }
                    } else {
                        gamelog("You cannot pick things up while zoomed out.",this.getFC())
                        
                    }
                } else {
                    gamelog("That hand is full.",this.getFC())
                }
                renderoo();
            }

            tryPickOut(hand, attempt, target) {//HELPER, DO NOT CALL
                let returnist = false;
                if (attempt >= target.inventory.length) {
                    //do nothing
                } else if (target.inventory[attempt] && target.inventory[attempt].totalMass > this.soul.carryingCapacity - this.burden) {
                    //try own inventory, else recurse
                    if (target.inventory[attempt].inventory && target.inventory[attempt].inventory.length > 0) {
                        //search own inventory
                        returnist = tryPickOut(hand, 0, target.inventory[attempt]);
                    } else{
                        //increment attmempt
                        returnist = this.tryPickOut(hand, attempt + 1, target);
                    }
                } else {
                    //just do it
                    this.soul.inHands[hand] = target.inventory[attempt];
                    //console.log(this.soul.inHands[hand]);
                    this.soul.inHands[hand].powers.forEach((element)=>{
                        useOnPickUp(this,element,this.soul.inHands[hand]);
                    });
                    target.inventory.splice(attempt,1);
                    returnist = true;
                }
                return returnist;
            }

            dropFromHand(hand) {
                if(this.soul.inHands[hand] != undefined) {
                    let tp = getWorld(this.x,this.y);
                    let pl = "s";
                    if (tp) {
                        tp.notable = true;
                        let personstr = "The".concat(this.genericName);
