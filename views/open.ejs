        class cultobj {
            constructor(culture,x,y) {
                this.culture = culture;
                this.x = x;
                this.y = y;
                [this.lowcoin, this.medcoin, this.highcoin] = createCoins(culture);
                this.enumx = Math.floor(x/32); //these are 8192*8192 normal tiles
                this.enumy = Math.floor(x/32); //also known as 32*32 regions
                this.landUseProportions = this.detLandUseProp(); //list where index0nothing, 1farms 2pastures 3orchards
                //its a running total and the last elt lup[3] should always be equal to or close to 1
                //The Following Code generates the temperature
                let hw = Math.abs((REGIONSIZE * this.x));
                let latfact = 64 / ((hw * 0.0000005) + 1); // that 0.0005 number = the smaller it is, the longer it takes for the temp to change
                let vation = allGensPerlin(REGIONSIZE * this.x, REGIONSIZE * this.y, twodorandom(Number(originalSeed), 1.613));
                let elevmult = 64 - ((64.0 / MAXELEV) * vation);
                //that code was taken straight from regions
                this.generalTemp = (latfact + ((Math.sqrt(latfact)) * (Math.sqrt(elevmult))));//yes, numbers are correct
                
                //this code is lifted from detmoist()
                let perlinvalue = rawPerlin(Number(REGIONSIZE * this.x), Number(REGIONSIZE * this.y), Number(2 ** 13), twodorandom(Number(originalSeed), 0.514));
                this.generalMoist = ((vation / (MAXELEV * 6)) + 0.9) * perlinvalue * 128.0;
                
                this.possibleCrops = [];
                Object.values(allCrops).forEach((e)=>{
                    //console.log(e);
                    if(e.mintemp <= this.generalTemp && e.maxtemp >= this.generalTemp && e.minmoist <= this.generalMoist && e.maxmoist >= this.generalMoist) {
                        this.possibleCrops.push(e);
                    }
                });
                
                //THINGS TAKEN OUT OF REGIONAL CODE FOLLOW
                this.possiblefurnitures = [];//
                for (let m = 0; m < 20; m++) {
                    this.possiblefurnitures.push(furniture[Math.floor(furniture.length*(twodorandom(this.culture,0.09264 + m)))]);
                    let h = twodorandom(m,this.culture);
                    if (h > 0.6) {
                        this.possiblefurnitures[m].material = randPracticalMaterial(x*REGIONSIZE,y*REGIONSIZE,twodorandom(m,this.culture));//suprisingly, this code works                      
                    }
                }
                this.buildings = [];
                for (let l = 0; l < 45; l++) {
                    this.buildings.push(randBuilding(twodorandom(this.culture,l+0.3),this.possiblefurnitures));
                }
                this.roadMat = roadMats[Math.floor(roadMats.length*twodorandom(this.culture,0.3432447))];
                this.roadWidth = 1+Math.floor(3*twodorandom(this.culture,0.5239587));
                this.roadalBuiltUpness = 1.75 * twodorandom(0.2345348569, this.culture);
                this.cityLayout = Math.floor(2*twodorandom(this.culture,0.3523));//0 = ns 1 = ew
                // NOW THAT WE'VE DONE THAT, population dynamics

                this.cityCount = 0;//this gets updated by createCities()
                this.cities = this.createCities(); //this is a list of cities, just the primary ones
                this.otherTiles = this.createOthers();//this is a 2-d array of all the tiles,

                //okay now we are on pop dynn
                if (this.cityCount != 0) {
                    let tdr = twodorandom(twodorandom(x+0.362, y),this.culture);
                    this.totalPop = Math.floor((this.cityCount*(768/125))*(((Math.log(1/(1-tdr)))/(Math.log((4* Math.PI)/3)))+1));
                    let biggestPop = this.totalPop/(harmonicNum(this.cityCount));
                    let enumeration = [];
                    for (let i = 0; i < this.cityCount; i++) {
                        enumeration[i] = i;
                    }
                    enumeration.sort((a,b) =>{
                        let trd = twodorandom(a+this.culture, b+originalSeed);
                        if (trd > 0.5) {
                            return 1
                        } else {
                            return -1;
                        }
                    });

                    //we renadom ize the list of cities
                    //for each city, we find its population given the total regional pop and the number of cities
                    let tp = 0;
                    let iter = 1;
                    enumeration.forEach((element) =>{
                        let cy = this.cities[element];
                        cy.population = Math.floor(biggestPop/iter);
                        tp += cy.population;
                        iter++;
                    });
                    
                    this.cities[enumeration[0]].population += this.totalPop - tp;
                    //now we make the list of all the people
                    this.peopList = this.getPeopleList();
                    this.oldestPersonAgeYears = this.peopList[0].generationage;
                    this.alivePeopList = [];
                    this.peopList.forEach((l)=>{
                        if (l.isAlive) {
                            this.alivePeopList.push(l);
                        }
                    });
                    //
                    this.driveBuildingPlacement();
                }
            }

            
            detLandUseProp() {
                let returnist = [];
                let cld = 1;
                let fect = Math.abs(this.enumx * 64 * 32);
                if (fect < 1000000) {
                    cld = ((3 * fect)/100000) + 20;
                } else if (fect < 6000000) {
                    cld = 50;
                } else if (fect < 10000000) {
                    cld = ((247/2) - ((49 * fect)/4000000));
                } //cld ranges from 1(cold) to 50 (not)
                let no = 40 * twodorandom(this.culture,0.1);
                let farm = cld * twodorandom(this.culture,0.2);
                let past = (cld/1.5) * twodorandom(this.culture,0.4);
                let orch = (cld/4) * twodorandom(this.culture,0.5);
                let ttl = no + farm + past + orch;
                let adj = 1/ttl;
                returnist[0] = 40*adj;
                returnist[1] = (farm*adj) + returnist[0];
                returnist[2] = (past*adj) + returnist[1];
                returnist[3] = (orch*adj) + returnist[2]; 
                return returnist;
            }

            createCities() {
                let ret = [];
                let itr = 0;
                for (let i = 0; i < 32; i++) {
                    for (let j = 0; j < 32; j++) {
                        let cxr = (this.x) + i;
                        let cyr = (this.y) + j;
                        if ( detWhetherCity(cxr,cyr,originalSeed)&& getIdent(cxr,cyr,originalSeed) === this.culture) {
                            let e = new city(cxr,cyr,i,j,1,this.culture,itr,undefined,this.roadMat,this.roadWidth,this.roadalBuiltUpness,this.cityLayout);
                            ret.push(e);
                            itr++;
                            this.cityCount = itr;
                        }
                    }
                }
                return ret;
            }

            createOthers() {
                let ret = [];
                for (let i = 0; i < 32; i++) {
                    ret[i] = []
                    for (let j = 0; j < 32; j++) {
                        let cxr = (this.x ) + i;
                        let cyr = (this.y) + j;
                        let [dist,closest] = this.findDistanceToClosest(i,j);
                        if (dist == 0) {
                            ret[i][j]= closest;
                        } else {
                            let purp = 0;
                            let r0 = twodorandom(i + 0.3,j + this.culture);
                            if (r0 < (dist/5) * this.landUseProportions[0] || this.cityCount === 0) {
                                purp = 0;
                            } else {
                                let pnum = twodorandom(i + 0.63,j + this.culture);
                                if (pnum > this.landUseProportions[0]) {
                                    if (pnum < this.landUseProportions[1]) {
                                        purp = 2;
                                    } else if (pnum < this.landUseProportions[2]) {
                                        purp = 3;
                                    } else if (pnum < this.landUseProportions[3]) {
                                        purp = 4;
                                    } else {
                                        purp = 0;
                                    }
                                }
                            }
                            //figure this one out
                            let a = new city(cxr,cyr,i,j,purp,this.culture,undefined,closest,this.roadMat,this.roadWidth,this.roadalBuiltUpness,this.cityLayout);
                            //console.log(a);
                            ret[i][j] = a;
                        }
                    }
                }
                return ret;
            }

            findDistanceToClosest(i,j) {
                let ret = [10000000,undefined];
                if (this.cityCount != 0){
                    ret[0] = Math.sqrt(((this.cities[0].ix-i)**2) + ((this.cities[0].iy - j)**2));
                    ret[1] = this.cities[0];
                    this.cities.forEach((element)=>{
                        let dyst = Math.sqrt(((element.ix-i)**2) + ((element.iy - j)**2));
                        if (dyst < ret[0]) {
                            ret[0] = dyst;
                            ret[1] = element;
                        }
                    });
                } 
        
                return ret;
            }

            driveBuildingPlacement() {
                let placedSoFar = 0;
                this.cities.forEach((element)=>{
                    let ntp = element.population;
                    let ock = element.placeBuildings(element.population, this.cityLayout,this.buildings,this.roadWidth,this.alivePeopList,this.oldestPersonAgeYears,placedSoFar);
                    ntp -= ock;
                    placedSoFar += ock;
                    while (ntp > 0) {
                        let moth = this.findNearestChildNotAlreadyUrban(element);
                        if (moth == undefined) {
                            //console.log("Surprisingly, we didn't find it !!!!!!!!!!");
                            element.population -= ntp;
                            ntp = -1;
                        } else {
                            moth.purpose = 1;
                            let ack = moth.placeBuildings(ntp, this.cityLayout,this.buildings,this.roadWidth,this.alivePeopList,this.oldestPersonAgeYears,placedSoFar);
                            ntp -= ack;
                            placedSoFar+= ack;
                        }
                    }
                });
            }

            findNearestChildNotAlreadyUrban(city) {
                let ret = undefined;
                let best = 10000000;
                for (let i = 0; i < 32; i++) {
                    for (let j = 0; j < 32; j++) {
                        let ot = this.otherTiles[i][j];
                        //console.log(ot);
                        if (ot.parentcity == city && ot.distToParent < best && ot.purpose != 1) {
                            best = ot.distToParent;
                            ret = ot;
                        } 
                    }
                }
                //console.log ("ret is");
                //console.log(ret);
                return ret;
            }

            getPeopleList() {
                let subl = [];
                historicThingVec.forEach((e)=>{//YEEEEHAW we're doing it again!
                    if (e.CID && e.CID.culturenum == this.culture) {
                        subl.push(e);
                    }
                });
                let target = this.totalPop
                let ret = [];
                let curyear = 0;
                let startingpop = Math.floor(target / 3) + 1;
                let nsf = 0;
                for (let i = 0; i < startingpop; i++){
                    ret.push(new personalCulture(this.culture,this.x, this.y,undefined,undefined,i));
                    let ifal = getIfExistsFromHistList(ret[ret.length -1].CID,subl);
                    if (ifal) {
                        ret[ret.length -1].self = ifal;
                    }
                    nsf ++;
                }
                while (nsf < target) {
                    //console.log(`${nsf},${target}`);
                    curyear++;
                    //first do deaths & aging
                    ret.forEach((e) =>{
                        e.generationage++;
                        //console.log(e.generationage);
                        if (e.isAlive && twodorandom(e.number+this.culture,curyear+0.235) < 0.25 * (Math.tanh(0.1*(e.generationage - 90))+1)) {
                            e.isAlive = false;
                            nsf--;
                        }
                        //monetary things
                        if (e.isAlive) {
                            e.balance *= 1.03;//healthy 3% intrest rates
                        } else {
                            if (e.balance > 0 && e.children[0]) {
                                e.children[0].balance += e.balance;
                                e.balance = 0;
                            }
                        }
                    });
                    //then do professions
                    ret.forEach((e) =>{
                        if (e.generationage >= 17 && e.profession.getStr() === "unemployed") {
                            //console.log(this.possibleCrops);
                            e.profession = genProfession(e,this.possibleCrops,this.landUseProportions,this.totalPop);
                            this.assignToWorkplace(e);
                        }
                    });
                    //then do marriages
                    ret.forEach((e) =>{
                        if (e.sex == 0 && e.generationage >= 18 && e.spouse == undefined && e.isAlive) {
                            //console.log("trying to spouse");
                            //find this guy a spouse
                            for(let k = 0; k < ret.length; k++) {
                                if (ret[k].sex == 1 && ret[k].generationage >= ((e.generationage/2)+7) && ret[k].isAlive && ret[k].spouse == undefined && ret[k].name[ret[k].name.length -1] != e.name[e.name.length -1]) {
                                    //console.log("Good Spouse found");
                                    //good spouse
                                    e.spouse = ret[k];
                                    ret[k].spouse = e;
                                    ret[k].name[ret[k].name.length -1] = e.name[e.name.length -1];
                                    //escape
                                    k = ret.length + 235;
                                }
                            }
                        }
                    });
                    //then do births
                    ret.forEach((e) =>{
                        if (e.isAlive && e.sex == 1 && e.spouse && e.spouse.isAlive) {
                            //console.log("fertile");
                            //proving that is fertile femmale
                            let probToBaby = 0.9/(1 + (((e.generationage - 20.5)/7)**2));
                            
                            if (twodorandom(e.number + this.culture,curyear + 0.723) < probToBaby) {
                                //console.log("hb");
                                let bby = new personalCulture(this.culture,this.x,this.y,e,e.spouse,ret.length)
                                ret.push(bby);
                                let ifal = getIfExistsFromHistList(ret[ret.length -1].CID,subl);
                                if (ifal) {
                                    ret[ret.length -1].self = ifal;
                                }
                                nsf++;
                                e.children.push(bby);
                                e.spouse.children.push(bby);
                                let bbal = (e.balance/10) + (e.spouse.balance/10);
                                e.balance *= (9/10);
                                e.spouse.balance *= (9/10);
                                bby.balance = bbal;
                            }
                        }
                    });
                    //then do emergency person addition
                    if (nsf < target/6) {
                        ret.push(new personalCulture(this.culture,this.x, this.y,undefined,undefined,ret.length));
                        let ifal = getIfExistsFromHistList(ret[ret.length -1].CID,subl);
                        if (ifal) {
                            ret[ret.length -1].self = ifal;
                        }
                        nsf++;
                    }
                }
                //now the list is fjull. woo-hoo
                while (ret.length > target) {
                    ret.pop();
                }
                ret.sort((a,b)=>{
                    return a.name[a.name.length - 1].localeCompare(b.name[b.name.length - 1]);
                })
                return ret;
