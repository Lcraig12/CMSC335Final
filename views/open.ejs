        class city { //holds data about a certain region that is part of a culture
            //there are reasons that this is not just addl data inside of the region object.
            constructor(actualx,actualy,ix,iy,purpose,culture,enumeration,parent,roadTile,roadWidth,roadBuilt,cityLayout) {
                this.purpose = purpose;//purposes = 0fallow 1urban 2farmland 3pastures 4orchard
                this.actualx = actualx;
                this.actualy = actualy;
                this.culture = culture;
                this.name = "";
                if (this.purpose == 1) {
                    this.name = genRandName(twodorandom(actualx,actualy+0.35),this.culture)[0];
                }
                this.ix = ix;
                this.iy = iy;
                this.enum = enumeration;//only given to cities
                this.parentcity = parent;//only given to non-cities
                this.distToParent = 0;
                if (this.parentcity != undefined) {
                    this.distToParent = Math.sqrt(((this.ix - this.parentcity.ix)**2)+((this.iy - this.parentcity.iy)**2));
                }

                this.population = 0;//includes children. For locla population, use buildingCount (which hasn't been implemented yet)
                this.instBuildings = [];

                this.roadTile = roadTile;
                this.roadWidth = roadWidth;
                this.roadBuilt = roadBuilt;
                this.cityLayout = cityLayout;
                this.owner = undefined;//person's personal culture. For if a mine or farm or stately pleasure dome

                //The following is taken from The Old Region Code
                this.carpetMaterial=randPracticalMaterial(actualx*REGIONSIZE,actualy*REGIONSIZE,this.culture + 3.1);
                this.carpetColor = comborgbs(this.carpetMaterial.color, "#ffffff");
                this.wallMaterial=randPracticalMaterial(actualx*REGIONSIZE,actualy*REGIONSIZE,this.culture + 0.24);
                this.wallColor = this.wallMaterial.color;
                this.roadMaterial=randPracticalMaterial(actualx*REGIONSIZE,actualy*REGIONSIZE,this.culture + 64.246);
                this.roadColor = comborgbs(this.roadMaterial.color, "#ffffff");

                this.unfolded = false;
                
            }

            placeBuildings(numtoplace,direction,buildings,roadwidth,people,oldage,startdex) {//returns the number of buildings placed//
                let bs = this.createBuildingSequence(buildings);
                let mrun = REGIONSIZE/2 - roadwidth;
                let npla = 0;
                for (let i = 0; i < 8; i++) {
                    let doneness = false;
                    let j = 0;
                    while (!doneness) {
                        
                        //console.log(bs[npla]);
                        if (npla < numtoplace && bs[npla].width + 2 + j < mrun) {
                            let dir = 0;
                            
                            if (i == 2 || i==3 || i==6 || i==7) {
                                dir = 2;
                            }
                            dir += direction;//dir is now the direction the bldg is placed
                            let blax = 0; // the 'x' position
                            if (i == 1 || i == 3 || i ==5 || i==7) {
                                blax = REGIONSIZE/2 + roadwidth;
                            }
                            if (i == 2 || i==3 || i==6 || i==7) {
                                blax = REGIONSIZE - blax - 1;
                                blax = blax - j;
                            } else {
                                blax = blax + j;
                            }
                            let blay = 0;
                            let cl = REGIONSIZE/4;
                            if (i < 4) {
                                cl += REGIONSIZE/2;
                            }
                            let clm = 1;
                            if (i == 2 || i==3 || i==6 || i==7) {
                                clm = -1;
                            }
                            blay = cl + (clm * roadwidth);
                            /*
                            if (direction == 1) {//we swap x and y
                                let neutr = blax;
                                blax = blay;
                                blay = neutr;
                            }
                            */
                            this.instBuildings.push(new buildingInstance(bs[npla],dir,blax,blay,people[startdex + npla], oldage));
                            //fit another and increase j
                            //and increase numplaced
                            j += bs[npla].width + 2;
                            npla++;
                        } else {
                            doneness = true;
                        }
                    }
                }
                return npla;
            }

            createBuildingSequence(buildings) { //This code creates the list of buildings that this city will sip from
                let buildingSequence = [];
                let totalBuildingFrequency = 0;
                for (let i = 0; i < buildings.length; i++) {
                    totalBuildingFrequency += buildings[i].frequency;
                }
                for (let j = 0; j < 100; j++) {//100 is just to make sure there are enough buildings, even if they come out really small
                    let araund = totalBuildingFrequency*twodorandom(this.culture,twodorandom(j,twodorandom(this.actualx,this.actualy)));
                    for (let k = 0; k < buildings.length; k++) {
                        if (araund<buildings[k].frequency) {
                            buildingSequence.push(buildings[k]);
                            k = buildings.length+3; // just need to escape the loop
                        } else {
                            araund = araund-buildings[k].frequency;
                        }
                    }
                }
                return buildingSequence;
            }
        
            unfold() {//the function that gets called when the region that contains this one is loaded.
                //remember to also do roads
                
                let rgn = getWorld(this.actualx * REGIONSIZE,this.actualy * REGIONSIZE).parent;
                if (this.purpose == 1) {//purposes = 0fallow 1urban 2farmland 3pastures 4orchard
                    rgn.placeRoads(this.roadTile,this.roadWidth,this.roadBuilt,this.cityLayout,this.roadMaterial,this.roadColor);
                    this.instBuildings.forEach((element)=>{
                        element.placeSelf(rgn,this.culture,this.carpetColor,this.carpetMaterial,this.wallColor,this.wallMaterial);
                    });
                } else if (this.purpose == 2) {
                    if (this.owner != undefined) {
                        rgn.placeCrops(this.owner.profession.farmed_crop);
                    }
                } else if (this.purpose == 4) {
                    if (this.owner != undefined) {
                        rgn.placeTrees(this.owner.profession.farmed_crop);
                    }
                }
                this.unfolded = true;
            }
        }

