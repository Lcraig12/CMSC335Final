            a.isRadioactive || b.isRadioactive, avg(a.halfLife,b.halfLife),avg(a.electricalResistivity,b.electricalResistivity),avg(a.ppm,b.ppm),
            avg(a.value,b.value),avg(a.meltingPoint,b.meltingPoint),avg(a.boilingPoint,b.boilingPoint),a.isFlammable && b.isFlammable, 
            avg(a.flashPoint,b.flashPoint),avg(a.tensileStrength,b.tensileStrength),avg(a.tensileStrength,b.tensileStrength),
            a.edibility && b.edibility);
            return c;
        }

        function avg(a,b) {
            if (!a) {
                a = 0;
            }
            if (!b) {
                b = 0;
            }
            return (a + b)/2
        } 

        function materialwisexor(a,b) {
            if (a == undefined) {//yee this is all really lazy and i basically just re used the or
                return b;
            } else if (b == undefined) {
                return a;
            } else {
                let c = new material(stringwiseor(a.name,b.name),Math.max(a.density,b.density),comborgbs(a.color,b.color),Math.max(a.hardness,b.hardness),
                a.isRadioactive != b.isRadioactive, Math.max(a.halfLife,b.halfLife),Math.max(a.electricalResistivity,b.electricalResistivity),Math.max(a.ppm,b.ppm),
                Math.max(a.value,b.value),Math.max(a.meltingPoint,b.meltingPoint),Math.max(a.boilingPoint,b.boilingPoint),a.isFlammable != b.isFlammable, 
                Math.max(a.flashPoint,b.flashPoint),Math.max(a.tensileStrength,b.tensileStrength),Math.max(a.tensileStrength,b.tensileStrength),
                a.edibility != b.edibility);
                return c;
            }
        }

        function materialwiseor(a,b) {
            if (a == undefined) {
                return b;
            } else if (b == undefined) {
