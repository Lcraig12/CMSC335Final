        function twodorandom(a,b) {//good
            //console.log("randing");
            //console.log(a);
            //console.log(b);
            let a1 = ((((Math.abs(a) + 0.14643) % 2.23) +0.5 ) * 12.3)**2.57
            a1 = a1 % 0.9086234;
            //console.log(a1);
            let b1 = ((((Math.abs(b) + 0.12543) % 2.74) +0.6) * 11.3)**2.37
            b1 = b1 % 1.0363;
            //console.log(b1);
            let c = ((a1+9.0132353)**(b1+2.02332352)) + (a1 + b1);
