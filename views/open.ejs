            work(a) {
                let keeue = Object.values(allThingsDefault);
                //console.log(keeue);
                let b =  (keeue[Math.floor(keeue.length * twodorandom(currentTime, 3.263))]);
                let c = undefined;
                if (b.isLiving) {
                    c = randomItem(twodorandom(currentTime,originalSeed));
                } else {
                    c = createThingFromDefault(b,twodorandom(currentTime,0.2464));
                }
                c.hasHandle = false;
                c.material = a.material;
                c.recalculateSecondaryAttributes;
                let rf = a.nonHandleMass/c.nonHandleMass;
                c.bladeLength *=rf;
                c.addlVolume *=rf;
                c.armorialThickness *=rf;
                c.calculateSecondaryAttributes();
                return c;
