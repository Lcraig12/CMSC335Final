    <div id="character_creation">
        <h1 class="fancy">POWX</h1>
        <fieldset>
            <legend><strong>Character Creation</strong></legend>
            Name:<input type="text" id="ccname">
            <input type="radio" name="sexy" id="male">Male
            <input type="radio" name="sexy" id="female">Female <br>
            Upper Body Strength: <input type="range" step ="0.0001" min="0" max="2" id="upperBodyStrength" onchange="ccArgs()"><a id="dupperBodyStrength"></a><br>
            Skin Tone: <input type="range" step ="0.0001" min="0" max="2" id="skinTone" onchange="ccArgs()"><a id="dskinTone"></a><br>
            Vision: <input type="range" step ="0.0001" min="0" max="2" id="eyeSight" onchange="ccArgs()"><a id="deyeSight"></a><br>
            Leg Length: <input type="range" step ="0.0001" min="0.01" max="2" id="relativeLegLength" onchange="ccArgs()"><a id="drelativeLegLength"></a><br>
            Foot Size: <input type="range" step ="0.0001" min="0" max="2" id="relativeFootSize" onchange="ccArgs()"><a id="drelativeFootSize"></a><br>
            Hand Size: <input type="range" step ="0.0001" min="0" max="2" id="relativeHandSize" onchange="ccArgs()"><a id="drelativeHandSize"></a><br>
            Lower Body Strength: <input type="range" step ="0.0001" min="0.0001" max="2" id="lowerBodyStrength" onchange="ccArgs()"><a id="dlowerBodyStrength"></a><br>
            Height: <input type="range" step ="0.0001" min="0.00001" max="3.5" id="height" onchange="ccArgs()"><a id="dheight"></a> m<br>
            Heft: <input type="range" step ="0.0001" min="0" max="2" id="heft" onchange="ccArgs()"><a id="dheft"></a><br>
            Flexibility: <input type="range" step ="0.0001" min="0" max="2" id="flexibility" onchange="ccArgs()"><a id="dflexibility"></a><br>
            Core Strength: <input type="range" step ="0.0001" min="0" max="2" id="coreStrength" onchange="ccArgs()"><a id="dcoreStrength"></a><br>
            Broadness: <input type="range" step ="0.0001" min="0.00001" max="2" id="relativeBroadness" onchange="ccArgs()"><a id="drelativeBroadness"></a><br>
            Analytic Intelligence: <input type="range" step ="0.0001" min="0.01" max="2" id="analyticInt" onchange="ccArgs()"><a id="danalyticInt"></a><br>
            Emotional Intelligence: <input type="range" step ="0.0001" min="0" max="2" id="emotionalInt" onchange="ccArgs()"><a id="demotionalInt"></a><br>
            Reverence: <input type="range" step ="0.0001" min="0" max="2" id="reverence" onchange="ccArgs()"><a id="dreverence"></a><br>
            Aerobic Stamina: <input type="range" step ="0.0001" min="0" max="2" id="aerobicStamina" onchange="ccArgs()"><a id="daerobicStamina"></a><br>
            Anaerobic Stamina: <input type="range" step ="0.0001" min="0" max="2" id="anaerobicStamina" onchange="ccArgs()"><a id="danaerobicStamina"></a><br>
            Constitution: <input type="range" step ="0.0001" min="0" max="2" id="constitution" onchange="ccArgs()"><a id="dconstitution"></a><br>
