        function getCoinsAndCost(cultureb,dollard) {//returns [coin,cost]
            let lc = cultureb.lowcoin
            let mc = cultureb.medcoin;
            let hc = cultureb.highcoin;
            let ret = [lc,0];
            if (dollard/mc.totalValue > 2) {
                ret[0] = lc;
                if (dollard/hc.totalValue > 2) {
                    ret[0] = hc;
                }
            }
            ret[1] = 1 + Math.floor(dollard/ret[0].totalValue);
            //console.log(ret);
            //console.log(dollard);
            return ret;
        }

