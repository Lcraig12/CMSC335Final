                ["June","Ventôse","Poṭṭhapāda","Oguz","Liùyuè","Jumādā ath-Thāniyah"],
                ["July","Quintillis","Germinal","Assayuja","Gorkut","Qīyuè","Rajab"],
                ["August","Sextillis","Floréal","Kattika","Alp Arslan","Bāyuè","Shaʿbān"],
                ["September","Prairial","Māgasira","Ruhnama","Jiǔyuè","Ramaḍān"],
                ["October","Messidor","Phussa","Garaşsyzlyk","Shíyuè","Shawwāl"],
                ["November","Thermidor","Māgha","Sanjar","Dōngyuè","Ḏū al-Qa'dah"],
                ["December","Fructidor","Phagguṇa","Bitaraplyk","Làyuè","Ḏū al-Ḥijjah"],
                ["Undecember","Ṗagume","Adar"],
                ["Duodecember"],
                ["Tridecember"],
                ["Tetradecember"],
                ["Quintidecember"],
                ["Sextidecember"],
                ["Septedecember"],
                ["Octodecember"],
                ["Novodecember"],
                ["Viginter"],
                ["Unviginter"],
                ["Duoviginter"],
                ["Triviginter"],
                ["Tetraviginter"],
                ["Quintiviginter"],
                ["Sextiviginter"],
                ["Septeviginter"]];
            let maxDiffFromDefMonLen = (1/tdrcw(originalSeed,3.1))-1 ;
            let stdMonthLen = Math.floor(Math.min(60 * tdrcw(originalSeed,2.5), 60 * tdrcw(4.2,originalSeed)) + 2);
            let monthCount = 2 + Math.floor(27 * twodorandom(originalSeed,0.7534));
            for (let i = 0; i < monthCount; i++) {
                monthNames[i] = posMonthNames[i][Math.floor(posMonthNames[i].length * twodorandom(i+0.0235,originalSeed))];
                let justor = maxDiffFromDefMonLen - (2 * maxDiffFromDefMonLen * twodorandom(originalSeed,0.8453));
                monthLengths[i] = Math.max(1,Math.floor(stdMonthLen + justor));
                daysInAYear += monthLengths[i];
            }
            timeOffset = Math.floor(5000000000 - (10000000000 * twodorandom(originalSeed,0.23532)));
            document.getElementById("timedataa").innerHTML = getDateString(currentTime);//one time thing
        }

        function getDateString(thyme) {
            let a = thyme + timeOffset
            let daynum = Math.floor(a/86400);
            let curyear = Math.floor(daynum/daysInAYear);
            let doy = daynum - (curyear*daysInAYear);
            let finm = "";
            let iter = 0;
            let dayofMonth = 0;
            monthLengths.forEach((e)=>{
                if (doy > e) {
                    doy -= e;
                } else {
                    dayofMonth = doy;
                    doy = 1000000000;
                    
                    finm = monthNames[iter];
                }
                iter++;
            });
            let mds = "th";
            if (dayofMonth % 10 == 1 && dayofMonth != 11) {
                mds = "st";
            } else if (dayofMonth % 10 == 2 && dayofMonth != 12) {
                mds = "nd";
            } else if (dayofMonth % 10 == 3 && dayofMonth != 13) {
                mds = "rd";
            }
            let remainingtime = a - (daynum*86400);
            let dt = new Date(remainingtime * 1000);
            let hours = dt.getUTCHours();
            let minutes = dt.getMinutes();
            let seconds = dt.getSeconds();
            return(`${hours.toString().padStart(2,"0")}:${minutes.toString().padStart(2,"0")}:${seconds.toString().padStart(2,"0")}, ${finm} ${dayofMonth}${mds}, ${curyear}`);
        }

