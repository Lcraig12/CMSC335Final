                        } else {
                            //console.log("3762");
                            if (!useOnUse(this,this.soul.inHands[1].powers[0],this.soul.inHands[1])) {
                                //console.log("3766");
                                this.tryToUse(iter+1);
                            }
                        }
                    }
                }
            }

