        class Tvc {
            constructor(x, y) {
                this.x = x;
                this.y = y;
            }

            dot(ovec) {
                return ((this.x * ovec.x) + (this.y * ovec.y));
            }
        }

        function Shuffle(arrayToShuffle, seed) {
            for (let e = arrayToShuffle.length - 1; e > 0; e--) {
                //console.log(seed);
                const index = Math.round(twodorandom(seed, e) * (e - 1));
                const temp = arrayToShuffle[e];
                //do not need this one anymore

                arrayToShuffle[e] = arrayToShuffle[index];
                arrayToShuffle[index] = temp;
            }
        }

        function doP() {
            const permutation = [];
            for (let i = 0; i < 256; i++) {
                permutation.push(i);
            }
            originalSeed = Number(document.getElementById("seedling").value);
            Shuffle(permutation, originalSeed);

            for (let i = 0; i < 256; i++) {
                permutation.push(permutation[i]);
            }

            return permutation;
        }
        let Permutation = null;

        function doperlinthings() {
            Permutation = doP();
        }

        function GetConstantVector(v) {
            // v is the value from the permutation table
            const h = v & 3;
            if (h == 0)
                return new Tvc(1.0, 1.0);
            else if (h == 1)
                return new Tvc(-1.0, 1.0);
            else if (h == 2)
                return new Tvc(-1.0, -1.0);
            else
                return new Tvc(1.0, -1.0);
        }

        function smear(t) {
            return ((6 * t - 15) * t + 10) * t * t * t;
        }

        function marnet(t, a1, a2) {
            return a1 + t * (a2 - a1);
        }

        function evenRawer(x, y) {//this is some really good code
            const X = Math.floor(x) & 255;
            const Y = Math.floor(y) & 255;

            const xf = x - Math.floor(x);
            const yf = y - Math.floor(y);

            const topRight = new Tvc(xf - 1.0, yf - 1.0);
            const topLeft = new Tvc(xf, yf - 1.0);
            const bottomRight = new Tvc(xf - 1.0, yf);
            const bottomLeft = new Tvc(xf, yf);

            const valueTopRight = Permutation[Permutation[X + 1] + Y + 1];
            const valueTopLeft = Permutation[Permutation[X] + Y + 1];
            const valueBottomRight = Permutation[Permutation[X + 1] + Y];
            const valueBottomLeft = Permutation[Permutation[X] + Y];

            const dotTopRight = topRight.dot(GetConstantVector(valueTopRight));
            const dotTopLeft = topLeft.dot(GetConstantVector(valueTopLeft));
            const dotBottomRight = bottomRight.dot(GetConstantVector(valueBottomRight));
            const dotBottomLeft = bottomLeft.dot(GetConstantVector(valueBottomLeft));

            const u = smear(xf);
            const v = smear(yf);

            return marnet(u,
                marnet(v, dotBottomLeft, dotTopLeft),
                marnet(v, dotBottomRight, dotTopRight)
            );
        }
