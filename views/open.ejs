                }
            }

            addEffect(effectobj) {
                //console.log(effectobj);
                let e = parsonsClone(effectobj);
                e.timeOfPush = currentTime;
                this.effects.push(e);
                e.doOnStart(this);
            }

            removeEffect(effectname) {
                let doneness = false;
                let iter = this.effects.length -1;
                while(!doneness && iter >= 0) {
                    if (this.effects[iter].name != effectname) {
                        this.effects[iter].doOnEnd(this);
                        iter--;
                    } else {
                        doneness = true;
                        this.effects[iter].doOnEnd(this);
                        this.effects.splice(iter,1);
                    }
                }
                while (iter < this.effects.length) {
                    this.effects[iter].doOnStart();
                }
            }
        
